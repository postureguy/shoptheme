{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section
  class="pgm-testi pgm-section"
  aria-labelledby="pgm-testi-heading"
  itemscope
  itemtype="https://schema.org/Product"
>

  <!-- Hidden aggregate rating for SEO rich snippets -->
  <div itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating" class="pgm-sr-only">
    <meta itemprop="ratingValue" content="4.9">
    <meta itemprop="reviewCount" content="2000">
    <meta itemprop="bestRating" content="5">
    <meta itemprop="name" content="Posture Guy Mike Membership Program">
  </div>

  <div class="pgm-testi__inner">

    <!-- Section header -->
    <div class="pgm-testi__header">
      <span class="pgm-eyebrow pgm-testi__eyebrow">{{ section.settings.eyebrow | default: 'Real People. Real Results.' }}</span>
      <h2 class="pgm-testi__h2" id="pgm-testi-heading">
        {{ section.settings.heading | default: 'What Happens When You Fix the Root Cause' }}
      </h2>
    </div>

    <!-- Trust bar -->
    {%- if section.settings.show_trust_bar != false -%}
      <div class="pgm-testi__trust-bar" aria-label="Program overview">
        <span>
          <span class="pgm-testi__trust-star">★</span>
          {{ section.settings.trust_bar_rating | default: '4.9 / 5 Rating' }}
        </span>
        <span class="pgm-testi__trust-divider" aria-hidden="true">·</span>
        <span>{{ section.settings.trust_bar_members | default: '2,000+ Members' }}</span>
        <span class="pgm-testi__trust-divider" aria-hidden="true">·</span>
        <span>{{ section.settings.trust_bar_guarantee | default: '30-Day Guarantee' }}</span>
      </div>
    {%- endif -%}

    <!-- Testimonial grid -->
    <div class="pgm-testi__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <article
            class="pgm-testi__card{% if forloop.first %} pgm-testi__card--hero{% endif %}{% if forloop.last %} pgm-testi__card--wide{% endif %}"
            role="listitem"
            {{ block.shopify_attributes }}
            itemscope
            itemtype="https://schema.org/Review"
          >
            <meta itemprop="reviewRating" content="5">
            <meta itemprop="reviewBody" content="{{ block.settings.quote | escape }}">

            <div class="pgm-testi__stars" aria-label="5 out of 5 stars">
              <span aria-hidden="true">★★★★★</span>
              <span class="pgm-testi__stars-text">5/5</span>
            </div>

            <div class="pgm-testi__quote-wrap">
              <blockquote class="pgm-testi__quote">
                "{{ block.settings.quote }}"
              </blockquote>
            </div>

            <footer class="pgm-testi__footer">
              <div class="pgm-testi__avatar" aria-hidden="true">
                {{ block.settings.name | slice: 0 | upcase }}
              </div>
              <div>
                <div
                  class="pgm-testi__name"
                  itemprop="author"
                  itemscope
                  itemtype="https://schema.org/Person"
                >
                  <span itemprop="name">{{ block.settings.name }}</span>
                </div>
                <div class="pgm-testi__detail">{{ block.settings.location }}</div>
                {%- if block.settings.result != blank -%}
                  <span class="pgm-testi__result">{{ block.settings.result }}</span>
                {%- endif -%}
              </div>
            </footer>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Testimonials",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real People. Real Results." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Happens When You Fix the Root Cause" },
    { "type": "header", "content": "Trust Bar" },
    { "type": "checkbox", "id": "show_trust_bar", "label": "Show trust bar", "default": true },
    { "type": "text", "id": "trust_bar_rating", "label": "Rating text", "default": "4.9 / 5 Rating" },
    { "type": "text", "id": "trust_bar_members", "label": "Members text", "default": "2,000+ Members" },
    { "type": "text", "id": "trust_bar_guarantee", "label": "Guarantee text", "default": "30-Day Guarantee" }
  ],
  "blocks": [
    {
      "type": "testimonial",
