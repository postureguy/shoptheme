{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-testi pgm-section" aria-labelledby="pgm-testi-heading">
  <div class="pgm-testi__inner">

    <div class="pgm-testi__header">
      <span class="pgm-eyebrow pgm-testi__eyebrow">{{ section.settings.eyebrow | default: 'Real People. Real Results.' }}</span>
      <h2 class="pgm-testi__h2" id="pgm-testi-heading">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div class="pgm-testi__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <article class="pgm-testi__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="pgm-testi__stars" aria-label="5 stars">★★★★★</div>
            <blockquote class="pgm-testi__quote">
              "{{ block.settings.quote }}"
            </blockquote>
            <footer class="pgm-testi__footer">
              <div class="pgm-testi__avatar" aria-hidden="true">
                {{ block.settings.name | slice: 0 | upcase }}
              </div>
              <div>
                <div class="pgm-testi__name">{{ block.settings.name }}</div>
                <div class="pgm-testi__detail">{{ block.settings.location }}</div>
                {%- if block.settings.result != blank -%}
                  <span class="pgm-testi__result">{{ block.settings.result }}</span>
                {%- endif -%}
              </div>
            </footer>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Testimonials",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",  "default": "Real People. Real Results." },
    { "type": "text", "id": "heading", "label": "Heading",  "default": "Thousands Have Fixed Their Posture. You're Next." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote",    "label": "Quote",            "default": "I had chronic lower back pain for 6 years. After 3 weeks in the program, I woke up pain-free for the first time." },
        { "type": "text",     "id": "name",     "label": "Customer name",    "default": "Sarah M." },
        { "type": "text",     "id": "location", "label": "Location or role", "default": "Member since 2023 · Denver, CO" },
        { "type": "text",     "id": "result",   "label": "Result tag (optional)", "default": "Pain-free in 3 weeks" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Testimonials",
      "blocks": [
        {
