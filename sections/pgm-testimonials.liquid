{{ 'pgm-home.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Home Testimonials
  3-column card grid with star ratings and decorative quote marks.
  Up to 5 testimonials via blocks.
{%- endcomment -%}

{%- assign test_heading = section.settings.heading | default: 'What Members Are Saying' -%}
{%- assign test_sub     = section.settings.subheading | default: 'Real people. Real results. Real posture transformations.' -%}

<section
  class="pgm-home-testimonials"
  id="pgm-home-testimonials-{{ section.id }}"
  aria-labelledby="pgm-home-testimonials-heading-{{ section.id }}"
>
  <div class="pgm-home-testimonials__inner">

    <div class="pgm-home-testimonials__header">
      {%- if test_heading != blank -%}
        <h2 class="pgm-home-testimonials__heading" id="pgm-home-testimonials-heading-{{ section.id }}">
          {{ test_heading }}
        </h2>
      {%- endif -%}
      {%- if test_sub != blank -%}
        <p class="pgm-home-testimonials__subheading">{{ test_sub }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="pgm-home-testimonials__grid" role="list" aria-label="Customer testimonials">

        {%- for block in section.blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}

          <article
            class="pgm-home-testimonials__card"
            role="listitem"
            {{ block.shopify_attributes }}
          >

            <div class="pgm-home-testimonials__quote-mark" aria-hidden="true">
              <svg viewBox="0 0 40 28" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="28">
                <path d="M0 28V17.333C0 7.556 5.333 2.222 16 0l2.667 4C13.333 5.778 10.444 8.667 10 13.333H18V28H0zm22 0V17.333C22 7.556 27.333 2.222 38 0l2.667 4c-5.334 1.778-8.223 4.667-8.667 9.333H40V28H22z" fill="var(--pgm-blue)" opacity="0.18"/>
              </svg>
            </div>

            {%- comment -%} Star rating {%- endcomment -%}
            <div class="pgm-home-testimonials__stars" aria-label="{{ rating }} out of 5 stars" role="img">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <svg class="pgm-home-testimonials__star pgm-home-testimonials__star--filled" viewBox="0 0 16 16" fill="none" aria-hidden="true" width="16" height="16">
                    <path d="M8 1.5l1.854 3.756 4.146.603-3 2.924.708 4.131L8 10.75l-3.708 1.95.708-4.131L2 5.859l4.146-.603L8 1.5z" fill="#f59e0b" stroke="#f59e0b" stroke-width="0.5" stroke-linejoin="round"/>
                  </svg>
                {%- else -%}
                  <svg class="pgm-home-testimonials__star pgm-home-testimonials__star--empty" viewBox="0 0 16 16" fill="none" aria-hidden="true" width="16" height="16">
                    <path d="M8 1.5l1.854 3.756 4.146.603-3 2.924.708 4.131L8 10.75l-3.708 1.95.708-4.131L2 5.859l4.146-.603L8 1.5z" fill="none" stroke="#d1d5db" stroke-width="1" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- comment -%} Quote {%- endcomment -%}
            {%- if block.settings.quote != blank -%}
              <blockquote class="pgm-home-testimonials__quote">
                <p>{{ block.settings.quote }}</p>
              </blockquote>
            {%- endif -%}

            {%- comment -%} Author {%- endcomment -%}
            <footer class="pgm-home-testimonials__author">
              <span class="pgm-home-testimonials__author-name">{{ block.settings.author_name | default: 'Happy Member' }}</span>
              {%- if block.settings.author_title != blank -%}
                <span class="pgm-home-testimonials__author-title">{{ block.settings.author_title }}</span>
              {%- endif -%}
            </footer>

          </article>
        {%- endfor -%}

      </div>
    {%- else -%}
      <p class="pgm-home-testimonials__empty">Add testimonial blocks in the Shopify editor to display reviews here.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PGM — Home Testimonials",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What Members Are Saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Real people. Real results. Real posture transformations."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I've struggled with back pain for years. After just 4 weeks inside the membership, I finally feel relief. Mike's programs actually work."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title or location",
          "default": "Member since 2023"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Home Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I've struggled with back pain for years. After just 4 weeks inside the membership, I finally feel relief. Mike's programs actually work.",
            "author_name": "Sarah M.",
            "author_title": "Member since 2023",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "My posture has completely transformed. I stand taller, my shoulder pain is gone, and I feel more confident every day.",
            "author_name": "James T.",
            "author_title": "Member since 2022",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Worth every penny. The programs are easy to follow and Mike explains everything clearly. I've recommended it to everyone I know.",
            "author_name": "Lisa R.",
            "author_title": "Member since 2024",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
