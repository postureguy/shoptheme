{{ 'pgm-programs.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Program Related
  3-column mini card grid of related programs.
  Loads each program by metaobject handle.
{%- endcomment -%}

{%- assign handles = '' -%}
{%- if section.settings.program_handle_1 != blank -%}
  {%- assign handles = handles | append: section.settings.program_handle_1 -%}
{%- endif -%}
{%- if section.settings.program_handle_2 != blank -%}
  {%- if handles != '' -%}
    {%- assign handles = handles | append: ',' -%}
  {%- endif -%}
  {%- assign handles = handles | append: section.settings.program_handle_2 -%}
{%- endif -%}
{%- if section.settings.program_handle_3 != blank -%}
  {%- if handles != '' -%}
    {%- assign handles = handles | append: ',' -%}
  {%- endif -%}
  {%- assign handles = handles | append: section.settings.program_handle_3 -%}
{%- endif -%}

{%- assign handle_list = handles | split: ',' -%}

{%- comment -%} Don't render if no related programs configured {%- endcomment -%}
{%- if handle_list.size == 0 -%}{% endif -%}

<section
  class="pgm-program-related pgm-section"
  id="pgm-program-related-{{ section.id }}"
  aria-label="Related programs"
>
  <div class="pgm-program-related__inner">

    <div class="pgm-program-related__header">
      <h2 class="pgm-program-related__heading">
        {{ section.settings.heading | default: 'You Might Also Need' }}
      </h2>
      <a href="{{ section.settings.see_all_url | default: '/pages/programs' }}" class="pgm-program-related__see-all">
        View All Programs
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2.5 7h9M7 3l4 4-4 4"/>
        </svg>
      </a>
    </div>

    {%- if handle_list.size > 0 -%}
      <div class="pgm-program-related__grid" role="list">
        {%- for handle in handle_list -%}
          {%- assign h = handle | strip -%}
          {%- assign rel_prog = shop.metaobjects.program[h] -%}

          {%- if rel_prog != blank -%}
            {%- assign rel_title    = rel_prog.title.value -%}
            {%- assign rel_tagline  = rel_prog.tagline.value -%}
            {%- assign rel_category = rel_prog.condition_category.value -%}
            {%- assign rel_image    = rel_prog.hero_image.value -%}
            {%- assign rel_videos   = rel_prog.video_count.value | default: 0 -%}
            {%- assign rel_diff     = rel_prog.difficulty.value | downcase | default: 'all-levels' -%}
            {%- assign rel_price    = rel_prog.price_label.value -%}
            {%- assign rel_price_sub = rel_prog.price_subtext.value -%}
            {%- assign rel_url      = rel_prog.page_url.value | default: '#' -%}
            {%- assign rel_popular  = rel_prog.is_popular.value -%}
            {%- assign rel_new      = rel_prog.is_new.value -%}
            {%- assign rel_featured = rel_prog.is_featured.value -%}

            <article class="pgm-program-card" role="listitem">

              <a href="{{ rel_url }}" class="pgm-program-card__img-wrap" tabindex="-1" aria-hidden="true">
                {%- if rel_image != blank -%}
                  {{
                    rel_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      alt: rel_title,
                      width: 600,
                      height: 338
                  }}
                {%- else -%}
                  <div class="pgm-program-card__img-placeholder" aria-hidden="true">
                    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M24 4C12.95 4 4 12.95 4 24s8.95 20 20 20 20-8.95 20-20S35.05 4 24 4zm-4 28.5v-17l12 8.5-12 8.5z" fill="currentColor" opacity="0.4"/>
                    </svg>
                  </div>
                {%- endif -%}

                {%- if rel_featured or rel_popular or rel_new -%}
                  <div class="pgm-program-card__badges" aria-label="Program highlights">
                    {%- if rel_featured -%}
                      <span class="pgm-program-card__badge pgm-program-card__badge--featured">Featured</span>
                    {%- endif -%}
                    {%- if rel_popular -%}
                      <span class="pgm-program-card__badge pgm-program-card__badge--popular">Popular</span>
                    {%- endif -%}
                    {%- if rel_new -%}
                      <span class="pgm-program-card__badge pgm-program-card__badge--new">New</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if rel_videos != blank and rel_videos != 0 -%}
                  <div class="pgm-program-card__video-count" aria-label="{{ rel_videos }} videos">
                    <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path d="M2 3.5A1.5 1.5 0 0 1 3.5 2h9A1.5 1.5 0 0 1 14 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 12.5v-9zM6.5 5.75v4.5L11 8l-4.5-2.25z"/>
                    </svg>
                    {{ rel_videos }} Videos
                  </div>
                {%- endif -%}
              </a>

              <div class="pgm-program-card__body">
                {%- if rel_category != blank -%}
                  <span class="pgm-program-card__category">{{ rel_category }}</span>
                {%- endif -%}

                <h3 class="pgm-program-card__title">
                  <a href="{{ rel_url }}" style="text-decoration:none;color:inherit;">{{ rel_title }}</a>
                </h3>

                {%- if rel_tagline != blank -%}
                  <p class="pgm-program-card__tagline">{{ rel_tagline }}</p>
                {%- endif -%}

                {%- if rel_diff != blank -%}
                  <div class="pgm-program-card__meta">
                    <span class="pgm-program-card__difficulty pgm-program-card__difficulty--{{ rel_diff | replace: ' ', '-' | downcase }}">
                      {{ rel_diff | capitalize }}
                    </span>
                  </div>
                {%- endif -%}
              </div>

              <div class="pgm-program-card__footer">
                <div>
                  {%- if rel_price != blank -%}
                    <div class="pgm-program-card__price">{{ rel_price }}</div>
                  {%- endif -%}
                  {%- if rel_price_sub != blank -%}
                    <span class="pgm-program-card__price-sub">{{ rel_price_sub }}</span>
                  {%- endif -%}
                </div>
                <a href="{{ rel_url }}" class="pgm-program-card__cta" aria-label="Start {{ rel_title }}">
                  Start Program
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4"/>
                  </svg>
                </a>
              </div>

            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PGM — Program Related",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "You Might Also Need"
    },
    {
      "type": "url",
      "id": "see_all_url",
      "label": "\"View All\" link",
      "info": "Defaults to /pages/programs"
    },
    {
      "type": "header",
      "content": "Related Program 1"
    },
    {
      "type": "text",
      "id": "program_handle_1",
      "label": "Program handle",
      "info": "Metaobject handle (e.g. rounded-shoulders)"
    },
    {
      "type": "header",
      "content": "Related Program 2"
    },
    {
      "type": "text",
      "id": "program_handle_2",
      "label": "Program handle"
    },
    {
      "type": "header",
      "content": "Related Program 3"
    },
    {
      "type": "text",
      "id": "program_handle_3",
      "label": "Program handle"
    }
  ],
  "presets": [
    {
      "name": "PGM — Program Related"
    }
  ]
}
{% endschema %}
