{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<style>
.pgm-richtext { padding: 9.6rem 0; }
.pgm-richtext--bg-white { background: #fff; }
.pgm-richtext--bg-light { background: #f8f8f6; }
.pgm-richtext--bg-dark  { background: var(--pgm-dark); }
.pgm-richtext__inner {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 2.4rem;
  text-align: center;
}
.pgm-richtext__eyebrow {
  display: block;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pgm-blue);
  margin-bottom: 1.2rem;
}
.pgm-richtext__h2 {
  font-family: var(--pgm-head);
  font-size: clamp(2.4rem, 3.5vw, 4rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 3.2rem;
}
.pgm-richtext--bg-dark .pgm-richtext__h2  { color: #fff; }
.pgm-richtext--bg-white .pgm-richtext__h2,
.pgm-richtext--bg-light .pgm-richtext__h2 { color: var(--pgm-dark); }
.pgm-richtext__body {
  text-align: left;
}
.pgm-richtext__body p {
  font-size: 1.7rem;
  line-height: 1.8;
  margin-bottom: 2rem;
}
.pgm-richtext__body p:last-child { margin-bottom: 0; }
.pgm-richtext--bg-dark .pgm-richtext__body p  { color: rgba(255,255,255,0.7); }
.pgm-richtext--bg-white .pgm-richtext__body p,
.pgm-richtext--bg-light .pgm-richtext__body p { color: #444; }
@media (max-width: 749px) {
  .pgm-richtext { padding: 6.4rem 0; }
}
</style>

<div class="pgm-richtext pgm-section pgm-richtext--bg-{{ section.settings.background }}">
  <div class="pgm-richtext__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="pgm-richtext__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="pgm-richtext__h2">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="pgm-richtext__body">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</div>


{% schema %}
{
  "name": "PGM — Rich Text",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text",     "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body",    "label": "Body text" },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "default": "light",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "light", "label": "Light gray" },
        { "value": "dark",  "label": "Dark" }
      ]
    }
  ],
  "presets": [{ "name": "PGM — Rich Text" }]
}
{% endschema %}
