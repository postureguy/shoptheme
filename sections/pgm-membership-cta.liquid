{{ 'pgm-home.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Home Membership CTA
  Dark/bold full-width section driving UScreen free trial signups.
{%- endcomment -%}

{%- assign mem_eyebrow  = section.settings.eyebrow | default: 'The Program That Changes Everything' -%}
{%- assign mem_heading  = section.settings.heading | default: 'Get Full Access to Every Program' -%}
{%- assign mem_body     = section.settings.body | default: 'Inside the Posture Guy Mike membership you get instant access to every postural alignment program, a growing library of follow-along routines, and the exact system I use with my private clients — all for less than a daily coffee.' -%}
{%- assign mem_cta_label = section.settings.cta_label | default: 'Start Free Trial' -%}
{%- assign mem_cta_url  = section.settings.cta_url | default: 'https://membership.postureguymike.com/checkout/new?o=151535' -%}
{%- assign mem_bg       = section.settings.background | default: 'dark' -%}

{%- assign default_features = '10+ Postural Alignment Programs,New routines added every month,Expert Q&A access,Follow-along video library' -%}
{%- assign features_raw = section.settings.features | default: default_features -%}
{%- assign features = features_raw | split: ',' -%}

<section
  class="pgm-home-membership pgm-home-membership--{{ mem_bg }}"
  id="pgm-home-membership-{{ section.id }}"
  aria-labelledby="pgm-home-membership-heading-{{ section.id }}"
>
  <div class="pgm-home-membership__inner">

    <div class="pgm-home-membership__text-col">

      {%- if mem_eyebrow != blank -%}
        <p class="pgm-home-membership__eyebrow">{{ mem_eyebrow }}</p>
      {%- endif -%}

      <h2 class="pgm-home-membership__heading" id="pgm-home-membership-heading-{{ section.id }}">
        {{ mem_heading }}
      </h2>

      {%- if mem_body != blank -%}
        <p class="pgm-home-membership__body">{{ mem_body }}</p>
      {%- endif -%}

      {%- if features.size > 0 -%}
        <ul class="pgm-home-membership__features" aria-label="Membership features">
          {%- for feature in features -%}
            {%- assign feature_trimmed = feature | strip -%}
            {%- if feature_trimmed != blank -%}
              <li class="pgm-home-membership__feature-item">
                <svg class="pgm-home-membership__feature-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20">
                  <circle cx="10" cy="10" r="10" fill="var(--pgm-blue)"/>
                  <path d="M5.5 10.5l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ feature_trimmed }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>

    <div class="pgm-home-membership__action-col">

      <div class="pgm-home-membership__price-card">

        <div class="pgm-home-membership__price">
          <span class="pgm-home-membership__price-from">From</span>
          <span class="pgm-home-membership__price-amount">$27</span>
          <span class="pgm-home-membership__price-period">/mo</span>
        </div>

        <p class="pgm-home-membership__price-note">Cancel anytime · No contracts</p>

        <a
          href="{{ mem_cta_url }}"
          class="pgm-home-membership__cta"
          aria-label="{{ mem_cta_label }}"
        >
          {{ mem_cta_label }}
          <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18">
            <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5"/>
          </svg>
        </a>

        <div class="pgm-home-membership__guarantee" aria-label="Money-back guarantee">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20">
            <path d="M10 2L3 5v5c0 4.418 3.134 8.307 7 9 3.866-.693 7-4.582 7-9V5l-7-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 10.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>30-day money-back guarantee</span>
        </div>

      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Home Membership CTA",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Program That Changes Everything"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Full Access to Every Program"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body paragraph",
      "default": "Inside the Posture Guy Mike membership you get instant access to every postural alignment program, a growing library of follow-along routines, and the exact system I use with my private clients — all for less than a daily coffee."
    },
    {
      "type": "textarea",
      "id": "features",
      "label": "Feature list (comma-separated)",
      "default": "10+ Postural Alignment Programs,New routines added every month,Expert Q&A access,Follow-along video library",
      "info": "Separate each feature with a comma. Up to 6 items recommended."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Start Free Trial"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background style",
      "options": [
        { "value": "dark", "label": "Dark (default)" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    }
  ],
  "presets": [
    {
      "name": "PGM — Home Membership CTA"
    }
  ]
}
{% endschema %}
