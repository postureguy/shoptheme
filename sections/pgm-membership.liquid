{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-mem pgm-section" aria-labelledby="pgm-mem-heading">
  <div class="pgm-mem__inner">

    <!-- Header -->
    <div class="pgm-mem__header">
      <span class="pgm-eyebrow pgm-mem__eyebrow">{{ section.settings.eyebrow | default: 'The Membership Program' }}</span>
      <h2 class="pgm-mem__h2" id="pgm-mem-heading">
        {{ section.settings.heading | default: 'Everything You Need to Fix Your Posture — In One Place' }}
      </h2>
      <p class="pgm-mem__sub">
        {{ section.settings.subheading | default: 'Not just videos. A complete posture transformation system with live classes, guided programs, personalized analysis, and a community that has your back.' }}
      </p>
    </div>

    <!-- Feature grid -->
    <div class="pgm-mem__features">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="pgm-mem__feature" {{ block.shopify_attributes }}>
            <div class="pgm-mem__feat-icon" aria-hidden="true">
              {%- case block.settings.icon_name -%}
                {%- when 'programs' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.024-.983a1.125 1.125 0 0 1 0 1.966l-5.603 3.113A1.125 1.125 0 0 1 9 15.113V8.887c0-.857.921-1.4 1.671-.983l5.603 3.113Z" clip-rule="evenodd"/>
                  </svg>
                {%- when 'live' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4.5 4.5a3 3 0 0 0-3 3v9a3 3 0 0 0 3 3h8.25a3 3 0 0 0 3-3v-9a3 3 0 0 0-3-3H4.5ZM19.94 18.75l-2.69-2.69V7.94l2.69-2.69c.944-.945 2.56-.276 2.56 1.06v11.38c0 1.336-1.616 2.005-2.56 1.06Z"/>
                  </svg>
                {%- when 'community' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z" clip-rule="evenodd"/>
                    <path d="M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z"/>
                  </svg>
                {%- when 'analysis' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75ZM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 0 1-1.875-1.875V8.625ZM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 0 1 3 19.875v-6.75Z"/>
                  </svg>
                {%- when 'hsa' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 0 0-1.032 0 11.209 11.209 0 0 1-7.877 3.08.75.75 0 0 0-.722.515A12.74 12.74 0 0 0 2.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 0 0 .374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 0 0-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.704-3.08Zm3.094 8.016a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
                  </svg>
                {%- when 'start' -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 0 1 .359.852L12.982 9.75h7.268a.75.75 0 0 1 .548 1.262l-10.5 11.25a.75.75 0 0 1-1.272-.71l1.992-7.302H3.75a.75.75 0 0 1-.548-1.262l10.5-11.25a.75.75 0 0 1 .913-.143Z" clip-rule="evenodd"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.024-.983a1.125 1.125 0 0 1 0 1.966l-5.603 3.113A1.125 1.125 0 0 1 9 15.113V8.887c0-.857.921-1.4 1.671-.983l5.603 3.113Z" clip-rule="evenodd"/>
                  </svg>
              {%- endcase -%}
            </div>
            <h3 class="pgm-mem__feat-title">{{ block.settings.title }}</h3>
            <p class="pgm-mem__feat-desc">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- CTA Panel -->
    <div class="pgm-mem__cta-panel">
      <div class="pgm-mem__cta-copy">
        <p class="pgm-mem__cta-heading">
          {{ section.settings.cta_heading | default: 'Ready to get out of pain? <span>Start free today.</span>' }}
        </p>
        <div class="pgm-mem__badges">
          <span class="pgm-mem__badge">✓ Free 3-day trial</span>
          <span class="pgm-mem__badge">✓ Cancel anytime</span>
          <span class="pgm-mem__badge">✓ HSA / FSA eligible</span>
          <span class="pgm-mem__badge">✓ iOS &amp; Android app</span>
          <span class="pgm-mem__badge">✓ Live classes with Mike</span>
          <span class="pgm-mem__badge">✓ Trusted by celebrities &amp; athletes</span>
          <span class="pgm-mem__badge">✓ 2,500+ active members</span>
          <span class="pgm-mem__badge">✓ 30-day satisfaction guarantee</span>
        </div>
      </div>
      <div class="pgm-mem__cta-actions">
        <a
          href="{{ section.settings.cta_url | default: 'https://membership.postureguymike.com/checkout/new?o=151535' }}"
          class="pgm-btn pgm-btn--primary"
          target="_blank" rel="noopener"
        >
          {{ section.settings.cta_label | default: 'Start My Free Trial' }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Membership",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "The Membership Program" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Everything You Need to Fix Your Posture — In One Place" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Not just videos. A complete posture transformation system with live classes, guided programs, personalized analysis, and a community that has your back." },
    { "type": "header",   "content": "CTA Panel" },
    { "type": "text",     "id": "cta_heading","label": "CTA heading", "default": "Ready to get out of pain? Start free today." },
    { "type": "text",     "id": "cta_label",  "label": "Button label", "default": "Start My Free Trial" },
    { "type": "url",      "id": "cta_url",    "label": "Button link",  "info": "Link to UScreen free trial" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Program Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "default": "programs",
          "options": [
            { "value": "programs",  "label": "On-Demand Programs (play)" },
            { "value": "live",      "label": "Live Classes (camera)" },
            { "value": "community", "label": "Community (people)" },
            { "value": "analysis",  "label": "Analysis (chart)" },
            { "value": "hsa",       "label": "HSA / FSA (shield)" },
            { "value": "start",     "label": "Start Here (bolt)" }
          ]
        },
        { "type": "text",     "id": "title",       "label": "Title",       "default": "On-Demand Programs" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Structured posture programs from beginner to advanced, guided by Mike at your own pace." }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Membership",
      "blocks": [
        { "type": "feature", "settings": { "icon_name": "programs",  "title": "On-Demand Programs",    "description": "Structured posture programs — beginner to advanced — available on iOS, Android, and desktop. Work at your own pace." } },
        { "type": "feature", "settings": { "icon_name": "live",      "title": "Live Classes with Mike", "description": "Join Mike live for real-time coaching, Q&A sessions, and posture challenges with prizes." } },
        { "type": "feature", "settings": { "icon_name": "community", "title": "Private Community",      "description": "Connect with thousands of members, share wins, ask questions, and get support on your posture journey." } },
        { "type": "feature", "settings": { "icon_name": "analysis",  "title": "Posture Analysis Tools", "description": "Built-in posture assessment tools to track your progress and personalise your program to your body's specific needs." } },
        { "type": "feature", "settings": { "icon_name": "hsa",       "title": "HSA/FSA Eligible",       "description": "Your health savings account may cover the cost of the program. The only posture app that qualifies." } },
        { "type": "feature", "settings": { "icon_name": "start",     "title": "Start Here Path",        "description": "New to the program? Our guided Start Here path removes all guesswork and gets you feeling better fast." } }
      ]
    }
  ]
}
{% endschema %}
