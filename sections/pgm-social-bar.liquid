{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-bar pgm-section" aria-label="Social media following">
  <div class="pgm-bar__inner">
    <p class="pgm-bar__label">{{ section.settings.label | default: 'Join millions who follow along' }}</p>

    <!-- Instagram -->
    <a
      href="{{ section.settings.ig_url | default: 'https://www.instagram.com/postureguymike' }}"
      class="pgm-bar__item"
      target="_blank" rel="noopener"
      aria-label="Follow on Instagram — {{ section.settings.ig_count | default: '1.3M' }} followers"
    >
      <span class="pgm-bar__icon pgm-bar__icon--ig">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </span>
      <span class="pgm-bar__meta">
        <span class="pgm-bar__count">{{ section.settings.ig_count | default: '1.3M' }}</span>
        <span class="pgm-bar__name">Instagram</span>
      </span>
    </a>

    <!-- TikTok -->
    <a
      href="{{ section.settings.tt_url | default: 'https://www.tiktok.com/@postureguy' }}"
      class="pgm-bar__item"
      target="_blank" rel="noopener"
      aria-label="Follow on TikTok — {{ section.settings.tt_count | default: '594K' }} followers"
    >
      <span class="pgm-bar__icon pgm-bar__icon--tt">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.26 8.26 0 004.84 1.56V6.87a4.85 4.85 0 01-1.07-.18z"/>
        </svg>
      </span>
      <span class="pgm-bar__meta">
        <span class="pgm-bar__count">{{ section.settings.tt_count | default: '594K' }}</span>
        <span class="pgm-bar__name">TikTok</span>
      </span>
    </a>

    <!-- YouTube -->
    <a
      href="{{ section.settings.yt_url | default: 'https://www.youtube.com/@postureguymike' }}"
      class="pgm-bar__item"
      target="_blank" rel="noopener"
      aria-label="Subscribe on YouTube — {{ section.settings.yt_count | default: '222K' }} subscribers"
    >
      <span class="pgm-bar__icon pgm-bar__icon--yt">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </span>
      <span class="pgm-bar__meta">
        <span class="pgm-bar__count">{{ section.settings.yt_count | default: '222K' }}</span>
        <span class="pgm-bar__name">YouTube</span>
      </span>
    </a>

    <!-- Facebook -->
    <a
      href="{{ section.settings.fb_url | default: 'https://www.facebook.com/postureguymike' }}"
      class="pgm-bar__item"
      target="_blank" rel="noopener"
      aria-label="Follow on Facebook — {{ section.settings.fb_count | default: '651K' }} followers"
    >
      <span class="pgm-bar__icon pgm-bar__icon--fb">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </span>
      <span class="pgm-bar__meta">
        <span class="pgm-bar__count">{{ section.settings.fb_count | default: '651K' }}</span>
        <span class="pgm-bar__name">Facebook</span>
      </span>
    </a>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Social Proof Bar",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "Join millions who follow along"
    },
    { "type": "header", "content": "Instagram" },
    { "type": "text", "id": "ig_count", "label": "Follower count", "default": "1.3M" },
    { "type": "url",  "id": "ig_url",   "label": "Profile URL" },
    { "type": "header", "content": "TikTok" },
    { "type": "text", "id": "tt_count", "label": "Follower count", "default": "594K" },
    { "type": "url",  "id": "tt_url",   "label": "Profile URL" },
    { "type": "header", "content": "YouTube" },
    { "type": "text", "id": "yt_count", "label": "Subscriber count", "default": "222K" },
    { "type": "url",  "id": "yt_url",   "label": "Channel URL" },
    { "type": "header", "content": "Facebook" },
    { "type": "text", "id": "fb_count", "label": "Follower count", "default": "651K" },
    { "type": "url",  "id": "fb_url",   "label": "Page URL" }
  ],
  "presets": [{ "name": "PGM — Social Proof Bar" }]
}
{% endschema %}
