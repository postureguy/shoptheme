{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<style>
.pgm-split { padding: 9.6rem 0; }
.pgm-split--bg-white  { background: #fff; }
.pgm-split--bg-light  { background: #f8f8f6; }
.pgm-split--bg-dark   { background: var(--pgm-dark); }
.pgm-split__inner { max-width: 120rem; margin: 0 auto; padding: 0 2.4rem; }
.pgm-split__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6.4rem;
  align-items: center;
}
.pgm-split__media {
  position: relative;
  border-radius: 1.6rem;
  overflow: hidden;
  aspect-ratio: 4/5;
}
.pgm-split__media img { width: 100%; height: 100%; object-fit: cover; }
.pgm-split__eyebrow {
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pgm-blue);
  margin-bottom: 1.2rem;
  display: block;
}
.pgm-split__h2 {
  font-family: var(--pgm-head);
  font-size: clamp(2.8rem, 3.5vw, 4rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 2.4rem;
}
.pgm-split--bg-dark .pgm-split__h2 { color: #fff; }
.pgm-split--bg-white .pgm-split__h2,
.pgm-split--bg-light .pgm-split__h2 { color: var(--pgm-dark); }
.pgm-split__body { font-size: 1.7rem; line-height: 1.75; }
.pgm-split--bg-dark .pgm-split__body { color: rgba(255,255,255,0.7); }
.pgm-split--bg-white .pgm-split__body,
.pgm-split--bg-light .pgm-split__body { color: #444; }
.pgm-split__body p { margin-bottom: 1.6rem; }
.pgm-split__body p:last-child { margin-bottom: 0; }
.pgm-split--img-right .pgm-split__media { order: 2; }
.pgm-split--img-right .pgm-split__content { order: 1; }
@media (max-width: 989px) {
  .pgm-split { padding: 6.4rem 0; }
  .pgm-split__grid { grid-template-columns: 1fr; gap: 4rem; }
  .pgm-split__media { width: 100%; max-width: 48rem; margin: 0 auto; aspect-ratio: 3/2; }
  .pgm-split--img-right .pgm-split__media,
  .pgm-split--img-right .pgm-split__content { order: unset; }
}
</style>

<div class="pgm-split pgm-section pgm-split--bg-{{ section.settings.background }} pgm-split--img-{{ section.settings.image_position }}">
  <div class="pgm-split__inner">
    <div class="pgm-split__grid">
      <div class="pgm-split__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Mike Boshnack' }}
        {%- else -%}
          <img src="{{ 'pgm-about.jpg' | asset_url }}" alt="Mike Boshnack" loading="lazy" width="900" height="1125">
        {%- endif -%}
      </div>
      <div class="pgm-split__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="pgm-split__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="pgm-split__h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <div class="pgm-split__body">{{ section.settings.body }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "PGM — Split Content",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "default": "left",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text",     "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body",    "label": "Body text" },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "default": "white",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "light", "label": "Light gray" },
        { "value": "dark",  "label": "Dark" }
      ]
    }
  ],
  "presets": [{ "name": "PGM — Split Content" }]
}
{% endschema %}
