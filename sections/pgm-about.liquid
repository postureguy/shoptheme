{{ 'pgm-home.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Home About
  Two-column section: left = Mike's photo, right = bio text + credentials + CTA.
{%- endcomment -%}

{%- assign about_eyebrow     = section.settings.eyebrow | default: 'Meet Your Coach' -%}
{%- assign about_heading     = section.settings.heading | default: 'Hi, I\'m Mike — The Posture Guy' -%}
{%- assign about_cta_label   = section.settings.cta_label | default: 'Learn More About Mike' -%}
{%- assign about_cta_url     = section.settings.cta_url | default: '/pages/about' -%}

{%- assign default_creds = 'Certified Postural Alignment Specialist,Trained at Egoscue University,Featured in Forbes & Men\'s Health,Helped 2,400+ people fix their posture' -%}
{%- assign creds_raw = section.settings.credentials | default: default_creds -%}
{%- assign credentials = creds_raw | split: ',' -%}

<section
  class="pgm-home-about"
  id="pgm-home-about-{{ section.id }}"
  aria-labelledby="pgm-home-about-heading-{{ section.id }}"
>
  <div class="pgm-home-about__inner">

    {%- comment -%} Left: Image {%- endcomment -%}
    <div class="pgm-home-about__image-col">
      {%- if section.settings.image != blank -%}
        <div class="pgm-home-about__image-wrap">
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              alt: about_heading,
              width: 900,
              height: 1100,
              class: 'pgm-home-about__image'
          }}
        </div>
      {%- else -%}
        <div class="pgm-home-about__image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="50" cy="38" r="24" fill="rgba(255,255,255,0.12)"/>
            <path d="M8 112c0-23.196 18.804-42 42-42s42 18.804 42 42" fill="rgba(255,255,255,0.08)"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Right: Text {%- endcomment -%}
    <div class="pgm-home-about__text-col">

      {%- if about_eyebrow != blank -%}
        <p class="pgm-home-about__eyebrow">{{ about_eyebrow }}</p>
      {%- endif -%}

      <h2 class="pgm-home-about__heading" id="pgm-home-about-heading-{{ section.id }}">
        {{ about_heading }}
      </h2>

      {%- if section.settings.body != blank -%}
        <div class="pgm-home-about__body rte">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if credentials.size > 0 -%}
        <ul class="pgm-home-about__credentials" aria-label="Credentials">
          {%- for cred in credentials -%}
            {%- assign cred_trimmed = cred | strip -%}
            {%- if cred_trimmed != blank -%}
              <li class="pgm-home-about__credential-item">
                <svg class="pgm-home-about__credential-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="18" height="18">
                  <circle cx="10" cy="10" r="9" fill="var(--pgm-blue)" opacity="0.15"/>
                  <path d="M5.5 10.5l3 3 6-6" stroke="var(--pgm-blue)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ cred_trimmed }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if about_cta_url != blank -%}
        <a href="{{ about_cta_url }}" class="pgm-home-about__cta" aria-label="{{ about_cta_label }}">
          {{ about_cta_label }}
          <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="16" height="16">
            <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5"/>
          </svg>
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "PGM — Home About",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Meet Your Coach"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hi, I'm Mike — The Posture Guy"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>I'm a certified postural alignment specialist who has spent over a decade helping people eliminate chronic pain, fix their posture, and move the way their body was designed to move.</p><p>After struggling with my own postural issues, I discovered the Egoscue Method and transformed my health. Now I share that same knowledge with over 1.3 million followers — and inside my membership, I help members get real, lasting results.</p>"
    },
    {
      "type": "textarea",
      "id": "credentials",
      "label": "Credentials (comma-separated)",
      "default": "Certified Postural Alignment Specialist,Trained at Egoscue University,Featured in Forbes & Men's Health,Helped 2,400+ people fix their posture",
      "info": "Separate each credential with a comma."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn More About Mike"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "info": "Defaults to /pages/about"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Mike's photo",
      "info": "Portrait orientation, approx 900×1100px recommended."
    }
  ],
  "presets": [
    {
      "name": "PGM — Home About"
    }
  ]
}
{% endschema %}
