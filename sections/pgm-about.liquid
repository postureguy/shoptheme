{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-about pgm-section" id="pgm-about" aria-labelledby="pgm-about-heading">
  <div class="pgm-about__inner">

    <!-- Image side -->
    <div class="pgm-about__media">
      <div class="pgm-about__img-wrap">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image.alt | default: 'Mike Boshnack — Posture Guy Mike, Certified Postural Alignment Specialist'
          }}
        {%- else -%}
          <img
            src="{{ 'pgm-about.jpg' | asset_url }}"
            alt="Mike Boshnack — Posture Guy Mike, Certified Postural Alignment Specialist"
            loading="lazy"
            width="900"
            height="1125"
          >
        {%- endif -%}
        <div class="pgm-about__cred-badge" aria-label="Mike's credential">
          <div class="pgm-about__cred-title">{{ section.settings.badge_title | default: 'Egoscue Certified' }}</div>
          <div class="pgm-about__cred-sub">{{ section.settings.badge_sub | default: 'Postural Alignment Specialist' }}</div>
        </div>
      </div>
    </div>

    <!-- Content side -->
    <div class="pgm-about__content">
      <span class="pgm-eyebrow pgm-about__eyebrow">{{ section.settings.eyebrow | default: 'The Coach Behind the Movement' }}</span>

      <h2 class="pgm-about__h2" id="pgm-about-heading">
        {{ section.settings.heading | default: 'Meet Mike — The Posture Expert Trusted by Millions' }}
      </h2>

      <!-- Credibility stats -->
      <div class="pgm-about__stats" aria-label="Mike's reach">
        <div class="pgm-about__stat">
          <span class="pgm-about__stat-n">2.5M+</span>
          <span class="pgm-about__stat-l">Social followers</span>
        </div>
        <div class="pgm-about__stat">
          <span class="pgm-about__stat-n">1M+</span>
          <span class="pgm-about__stat-l">People helped</span>
        </div>
        <div class="pgm-about__stat">
          <span class="pgm-about__stat-n">10+</span>
          <span class="pgm-about__stat-l">Years experience</span>
        </div>
      </div>

      <div class="pgm-about__body">
        {%- if section.settings.body != blank -%}
          {{ section.settings.body }}
        {%- else -%}
          <p>Mike Boshnack isn't just a trainer — he's a Certified Postural Alignment Specialist trained directly under the Egoscue Method at Egoscue University in Irvine, California. After watching his sister struggle with debilitating pain for years, Mike made it his mission to bring the same structural correction that professional athletes and celebrities receive into the hands of everyday people.</p>
          <p>Today, with over 2.5 million followers and more than a million people helped, Mike's method is proven: fix the root cause of pain — not just the symptoms — and your body will heal itself.</p>
        {%- endif -%}
      </div>

      <!-- Credential row -->
      <div class="pgm-about__cred-row">
        <div class="pgm-about__cred-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <div>
          <div class="pgm-about__cred-label">{{ section.settings.cred_label | default: 'Certified Postural Alignment Specialist' }}</div>
          <div class="pgm-about__cred-desc">{{ section.settings.cred_desc | default: 'Trained at Egoscue University · Irvine, CA' }}</div>
        </div>
      </div>

      <a href="{{ section.settings.cta_url | default: '/pages/about' }}" class="pgm-btn pgm-btn--dark">
        {{ section.settings.cta_label | default: 'Learn More About Mike →' }}
      </a>
    </div>

  </div>

  <!-- Celebrity / Athlete carousel — full width below the 2-col grid -->
  {%- assign celeb_blocks = section.blocks | where: 'type', 'celebrity' -%}
  {%- if celeb_blocks.size > 0 -%}
    <div class="pgm-about__celeb">
      <p class="pgm-about__celeb-label">{{ section.settings.celeb_label | default: 'Trusted by celebrities, athletes & professional teams' }}</p>
      <div class="pgm-about__celeb-strip" role="list" aria-label="Celebrity and athlete clients">
        {%- for block in section.blocks -%}
          {%- if block.type == 'celebrity' -%}
            <div class="pgm-about__celeb-item" role="listitem" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 200
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.name | default: 'Client'
                }}
              {%- else -%}
                <div class="pgm-about__celeb-placeholder" aria-hidden="true">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <span class="pgm-about__celeb-name">{{ block.settings.name }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "PGM — About Mike",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo of Mike",
      "info": "Recommended: 900×1160px portrait. Can be a professional coaching shot or candid action photo."
    },
    { "type": "text",    "id": "badge_title",  "label": "Image badge title",    "default": "Egoscue Certified" },
    { "type": "text",    "id": "badge_sub",    "label": "Image badge subtitle", "default": "Postural Alignment Specialist" },
    { "type": "text",    "id": "eyebrow",      "label": "Eyebrow",              "default": "The Coach Behind the Movement" },
    { "type": "text",    "id": "heading",      "label": "Heading",              "default": "Meet Mike — The Posture Expert Trusted by Millions" },
    { "type": "richtext","id": "body",         "label": "Body text",            "info": "Leave blank to use the default copy." },
    { "type": "text",    "id": "cred_label",   "label": "Credential label",     "default": "Certified Postural Alignment Specialist" },
    { "type": "text",    "id": "cred_desc",    "label": "Credential subtitle",  "default": "Trained at Egoscue University · Irvine, CA" },
    { "type": "text",    "id": "cta_label",    "label": "Button label",         "default": "Learn More About Mike →" },
    { "type": "url",     "id": "cta_url",      "label": "Button link" },
    { "type": "header",  "content": "Celebrity / Athlete Carousel" },
    { "type": "text",    "id": "celeb_label",  "label": "Carousel label",       "default": "Trusted by celebrities, athletes & professional teams" }
  ],
  "blocks": [
    {
      "type": "celebrity",
      "name": "Celebrity / Athlete",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo (square crop recommended)" },
        { "type": "text",         "id": "name",  "label": "Name / Role" }
      ]
    }
  ],
  "presets": [{ "name": "PGM — About Mike" }]
}
{% endschema %}
