{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-tips pgm-section" aria-labelledby="pgm-tips-heading">
  <div class="pgm-tips__inner">

    <div class="pgm-tips__header">
      <span class="pgm-eyebrow pgm-tips__eyebrow">{{ section.settings.eyebrow | default: 'Free Posture Education' }}</span>
      <h2 class="pgm-tips__h2" id="pgm-tips-heading">
        {{ section.settings.heading | default: 'Start Improving Your Posture Today' }}
      </h2>
    </div>

    <div class="pgm-tips__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tip' -%}
          <div class="pgm-tip" {{ block.shopify_attributes }}>
            <span class="pgm-tip__num" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <h3 class="pgm-tip__title">{{ block.settings.title }}</h3>
            <p class="pgm-tip__body">{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="pgm-tips__cta">
        <a href="{{ section.settings.cta_url | default: 'https://membership.postureguymike.com/checkout/new?o=151535' }}" class="pgm-btn pgm-btn--primary" target="_blank" rel="noopener">
          {{ section.settings.cta_label | default: 'Get the Full Program Free →' }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PGM — Posture Tips",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Free Posture Education" },
    { "type": "text", "id": "heading", "label": "Heading",  "default": "Start Improving Your Posture Today" },
    { "type": "text", "id": "cta_label","label": "CTA button label", "default": "Get the Full Program Free →" },
    { "type": "url",  "id": "cta_url",  "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Posture Tip",
      "settings": [
        { "type": "text",     "id": "title", "label": "Tip title", "default": "Check Your Head Position" },
        { "type": "textarea", "id": "body",  "label": "Tip body",  "default": "Your head should sit directly over your shoulders. Every inch it juts forward adds 10 lbs of pressure on your spine. Bring your ears over your shoulders." }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Posture Tips",
      "blocks": [
        {
          "type": "tip",
          "settings": {
            "title": "Stack Your Ears Over Shoulders",
            "body": "Forward head posture is the #1 driver of neck pain. Your head weighs 10-12 lbs — every inch it drifts forward doubles the load on your spine. Gently tuck your chin and lift the crown of your head."
          }
        },
        {
          "type": "tip",
          "settings": {
            "title": "Level Your Hips First",
            "body": "Most back pain starts at the pelvis, not the back. A tilted pelvis throws your entire spine out of alignment. The Egoscue method works from the ground up — correcting your hip position first changes everything above it."
          }
        },
        {
          "type": "tip",
          "settings": {
            "title": "Move Every 30 Minutes",
            "body": "Sitting is not the problem — staying still is. Set a timer and do 2 minutes of posture exercises every 30 minutes. This resets your muscle firing patterns and prevents the stiffness that leads to chronic pain."
          }
        }
      ]
    }
  ]
}
{% endschema %}
