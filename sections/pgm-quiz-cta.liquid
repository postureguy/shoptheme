{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

{% comment %}PGM Posture Score Quiz — email capture → modal quiz → Klaviyo{% endcomment %}
<section class="pgm-quiz pgm-section" aria-labelledby="pgm-quiz-heading">

  <!-- Left: image panel -->
  <div class="pgm-quiz__image">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          alt: section.settings.image.alt | default: 'Mike Boshnack posture coaching session'
      }}
    {%- else -%}
      <img
        src="{{ 'pgm-quiz.jpg' | asset_url }}"
        alt="Mike Boshnack posture coaching session"
        loading="lazy"
        width="800"
        height="800"
      >
    {%- endif -%}
  </div>

  <!-- Right: content panel -->
  <div class="pgm-quiz__content">
    <div class="pgm-quiz__inner">

      <h2 class="pgm-quiz__h2" id="pgm-quiz-heading">
        {{ section.settings.heading | default: "What's Your Posture Score?" }}
      </h2>
      <p class="pgm-quiz__sub">
        {{ section.settings.subheading | default: 'Take our free 2-minute Posture Score Quiz and get a personalized plan for fixing your specific pain points — delivered straight to your inbox.' }}
      </p>

      <!-- Perks -->
      <div class="pgm-quiz__perks" aria-label="What you'll get">
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Free personalized posture assessment
        </div>
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Custom exercise plan for your pain
        </div>
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Weekly posture tips from Mike
        </div>
      </div>

      <!-- Email capture — opens quiz modal on submit -->
      <form class="pgm-quiz__form" id="pgm-quiz-email-form" novalidate>
        <input
          type="email"
          id="pgm-quiz-email"
          class="pgm-quiz__input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email address' }}"
          required
          autocomplete="email"
          aria-label="Email address"
        >
        <button type="submit" class="pgm-quiz__submit">
          {{ section.settings.cta_label | default: 'Get My Free Score →' }}
        </button>
      </form>

      <p class="pgm-quiz__note">{{ section.settings.note | default: 'No spam, ever. Unsubscribe anytime. Join 50,000+ subscribers.' }}</p>

    </div>
  </div>

</section>

<!-- ── QUIZ MODAL ──────────────────────────────────── -->
<div id="pgm-quiz-modal" class="pgm-qm" role="dialog" aria-modal="true" aria-labelledby="pgm-qm-title" hidden>
  <div class="pgm-qm__backdrop"></div>
  <div class="pgm-qm__box">

    <!-- Close button -->
    <button class="pgm-qm__close" aria-label="Close quiz" id="pgm-qm-close">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 4l12 12M16 4L4 16"/>
      </svg>
    </button>

    <!-- Progress bar -->
    <div class="pgm-qm__progress-wrap" aria-hidden="true">
      <div class="pgm-qm__progress-bar" id="pgm-qm-progress"></div>
    </div>
    <p class="pgm-qm__step-label" id="pgm-qm-step-label"></p>

    <!-- Question screens -->
    <div class="pgm-qm__screens" id="pgm-qm-screens">

      <!-- Q1 -->
      <div class="pgm-qm__screen" data-screen="1">
        <h2 class="pgm-qm__q" id="pgm-qm-title">Where do you feel the most discomfort?</h2>
        <div class="pgm-qm__options">
          <button class="pgm-qm__opt" data-q="1" data-val="neck_shoulders" data-score="15">Neck &amp; shoulders</button>
          <button class="pgm-qm__opt" data-q="1" data-val="upper_back" data-score="12">Upper / mid back</button>
          <button class="pgm-qm__opt" data-q="1" data-val="lower_back" data-score="20">Lower back</button>
          <button class="pgm-qm__opt" data-q="1" data-val="hips_knees" data-score="14">Hips &amp; knees</button>
          <button class="pgm-qm__opt" data-q="1" data-val="multiple" data-score="25">Multiple areas</button>
        </div>
      </div>

      <!-- Q2 -->
      <div class="pgm-qm__screen" data-screen="2" hidden>
        <h2 class="pgm-qm__q">How long have you been dealing with this?</h2>
        <div class="pgm-qm__options">
          <button class="pgm-qm__opt" data-q="2" data-val="under_1mo" data-score="5">Just started — less than a month</button>
          <button class="pgm-qm__opt" data-q="2" data-val="few_months" data-score="10">A few months (1–6 months)</button>
          <button class="pgm-qm__opt" data-q="2" data-val="over_a_year" data-score="16">Over a year</button>
          <button class="pgm-qm__opt" data-q="2" data-val="many_years" data-score="20">Many years (5+)</button>
        </div>
      </div>

      <!-- Q3 -->
      <div class="pgm-qm__screen" data-screen="3" hidden>
        <h2 class="pgm-qm__q">How would you describe your typical day?</h2>
        <div class="pgm-qm__options">
          <button class="pgm-qm__opt" data-q="3" data-val="desk_worker" data-score="12">Desk worker — I sit most of the day</button>
          <button class="pgm-qm__opt" data-q="3" data-val="on_feet" data-score="8">On my feet — standing or walking a lot</button>
          <button class="pgm-qm__opt" data-q="3" data-val="mixed" data-score="5">Mix of sitting and standing</button>
          <button class="pgm-qm__opt" data-q="3" data-val="light_activity" data-score="6">Retired or light daily activity</button>
        </div>
      </div>

      <!-- Q4 -->
      <div class="pgm-qm__screen" data-screen="4" hidden>
        <h2 class="pgm-qm__q">Have you tried treating this pain before?</h2>
        <div class="pgm-qm__options">
          <button class="pgm-qm__opt" data-q="4" data-val="nothing_yet" data-score="5">I haven't tried anything yet</button>
          <button class="pgm-qm__opt" data-q="4" data-val="stretching_youtube" data-score="8">Stretching or YouTube exercises</button>
          <button class="pgm-qm__opt" data-q="4" data-val="chiro_pt" data-score="12">Chiropractor or physical therapy</button>
          <button class="pgm-qm__opt" data-q="4" data-val="tried_everything" data-score="15">I've tried everything — nothing has lasted</button>
        </div>
      </div>

      <!-- Q5 -->
      <div class="pgm-qm__screen" data-screen="5" hidden>
        <h2 class="pgm-qm__q">What's your #1 goal right now?</h2>
        <div class="pgm-qm__options">
          <button class="pgm-qm__opt" data-q="5" data-val="eliminate_pain" data-score="0">Get out of chronic pain</button>
          <button class="pgm-qm__opt" data-q="5" data-val="look_taller" data-score="0">Stand taller and look better</button>
          <button class="pgm-qm__opt" data-q="5" data-val="move_better" data-score="0">Move better and feel more flexible</button>
          <button class="pgm-qm__opt" data-q="5" data-val="all_above" data-score="0">All of the above</button>
        </div>
      </div>

      <!-- Calculating -->
      <div class="pgm-qm__screen pgm-qm__screen--calculating" data-screen="calculating" hidden>
        <div class="pgm-qm__spinner" aria-hidden="true"></div>
        <p class="pgm-qm__calculating-text">Analyzing your posture profile…</p>
      </div>

      <!-- Results -->
      <div class="pgm-qm__screen pgm-qm__screen--results" data-screen="results" hidden>
        <div class="pgm-qm__score-ring" aria-hidden="true">
          <svg viewBox="0 0 120 120" width="120" height="120">
            <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,.1)" stroke-width="10"/>
            <circle class="pgm-qm__score-arc" cx="60" cy="60" r="52" fill="none" stroke="#3b9cd8" stroke-width="10"
              stroke-linecap="round" stroke-dasharray="327" stroke-dashoffset="327"
              transform="rotate(-90 60 60)"/>
          </svg>
          <span class="pgm-qm__score-num" id="pgm-qm-score-num">—</span>
        </div>
        <h2 class="pgm-qm__result-headline" id="pgm-qm-result-headline"></h2>
        <p class="pgm-qm__result-body" id="pgm-qm-result-body"></p>
        <a
          href="{{ section.settings.trial_url | default: 'https://membership.postureguymike.com/checkout/new?o=151535' }}"
          class="pgm-qm__result-cta pgm-btn pgm-btn--primary"
        >
          {{ section.settings.result_cta_label | default: 'Start My Free Trial — Fix This Now' }}
        </a>
        <p class="pgm-qm__result-note">Free trial · Cancel anytime · Results in as little as 2 weeks</p>
      </div>

    </div><!-- /screens -->
  </div><!-- /box -->
</div><!-- /modal -->

<script>
(function () {
  var KLAVIYO_ID = {{ section.settings.klaviyo_id | default: 'RY86tU' | json }};
  var KLAVIYO_LIST_ID = {{ section.settings.klaviyo_list_id | default: '' | json }};

  var modal   = document.getElementById('pgm-quiz-modal');
  var form    = document.getElementById('pgm-quiz-email-form');
  var closeBtn = document.getElementById('pgm-qm-close');
  var progressBar = document.getElementById('pgm-qm-progress');
  var stepLabel   = document.getElementById('pgm-qm-step-label');

  var email   = '';
  var answers = {};
  var totalScore = 0;
  var TOTAL_QUESTIONS = 5;

  // ── Open / close ──────────────────────────────────
  function openModal() {
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    modal.querySelector('[data-screen="1"]').focus();
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    // reset
    email = ''; answers = {}; totalScore = 0;
    showScreen(1);
    document.getElementById('pgm-quiz-email').value = '';
  }

  // ── Email form submit ─────────────────────────────
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var input = document.getElementById('pgm-quiz-email');
    if (!input.checkValidity()) { input.reportValidity(); return; }
    email = input.value.trim();
    openModal();
    setProgress(1);
  });

  closeBtn.addEventListener('click', closeModal);
  modal.querySelector('.pgm-qm__backdrop').addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
  });

  // ── Screen navigation ─────────────────────────────
  function showScreen(key) {
    modal.querySelectorAll('.pgm-qm__screen').forEach(function (s) {
      s.setAttribute('hidden', '');
    });
    var target = modal.querySelector('[data-screen="' + key + '"]');
    if (target) target.removeAttribute('hidden');
  }

  function setProgress(step) {
    var pct = ((step - 1) / TOTAL_QUESTIONS) * 100;
    progressBar.style.width = pct + '%';
    stepLabel.textContent = step <= TOTAL_QUESTIONS
      ? 'Question ' + step + ' of ' + TOTAL_QUESTIONS
      : '';
  }

  // ── Answer selection ──────────────────────────────
  modal.addEventListener('click', function (e) {
    var btn = e.target.closest('.pgm-qm__opt');
    if (!btn) return;

    var q     = parseInt(btn.dataset.q, 10);
    var val   = btn.dataset.val;
    var score = parseInt(btn.dataset.score, 10) || 0;

    answers['q' + q] = val;
    totalScore += score;

    // Visual feedback
    btn.classList.add('pgm-qm__opt--selected');
    setTimeout(function () {
      btn.classList.remove('pgm-qm__opt--selected');
      if (q < TOTAL_QUESTIONS) {
        showScreen(q + 1);
        setProgress(q + 1);
      } else {
        // Done — show calculating
        showScreen('calculating');
        stepLabel.textContent = '';
        progressBar.style.width = '100%';
        setTimeout(showResults, 1800);
      }
    }, 320);
  });

  // ── Results ───────────────────────────────────────
  function showResults() {
    // Score: higher penalty = lower final score (out of 100)
    var finalScore = Math.max(22, Math.min(88, 100 - totalScore));
    var headline, body;

    if (finalScore < 40) {
      headline = 'Your posture needs urgent attention.';
      body = 'Your score suggests significant structural imbalances that are likely causing your chronic pain. The good news: this is exactly what Mike\'s program is designed to fix — without surgery or medication.';
    } else if (finalScore < 58) {
      headline = 'You have moderate posture imbalances.';
      body = 'Your score reveals correctable patterns that, left untreated, tend to worsen over time. Mike\'s method addresses the root cause so you can feel better in weeks — not months.';
    } else if (finalScore < 73) {
      headline = 'You have some correctable patterns.';
      body = 'You\'re not in bad shape, but your score shows specific areas that need structural correction. A targeted program will help you move better and prevent future pain.';
    } else {
      headline = 'Good foundation — let\'s optimize it.';
      body = 'You\'ve got a solid base. Mike\'s program will help you lock in your posture gains and build the kind of pain-free movement most people only dream about.';
    }

    document.getElementById('pgm-qm-score-num').textContent = finalScore;
    document.getElementById('pgm-qm-result-headline').textContent = headline;
    document.getElementById('pgm-qm-result-body').textContent = body;

    // Animate the score arc (327 = full circle circumference for r=52)
    var arc = modal.querySelector('.pgm-qm__score-arc');
    var offset = 327 - (finalScore / 100) * 327;
    setTimeout(function () { arc.style.strokeDashoffset = offset; }, 50);

    showScreen('results');

    // Submit to Klaviyo
    sendToKlaviyo(finalScore);
  }

  // ── Klaviyo ───────────────────────────────────────
  function sendToKlaviyo(score) {
    if (!email || !KLAVIYO_ID) return;

    var properties = {
      quiz_pain_area:           answers.q1 || '',
      quiz_duration:            answers.q2 || '',
      quiz_lifestyle:           answers.q3 || '',
      quiz_previous_solutions:  answers.q4 || '',
      quiz_goal:                answers.q5 || '',
      quiz_posture_score:       score,
      quiz_completed_at:        new Date().toISOString()
    };

    // 1. Identify / update profile
    fetch('https://a.klaviyo.com/client/profiles/?company_id=' + KLAVIYO_ID, {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'revision': '2023-12-15' },
      body: JSON.stringify({
        data: {
          type: 'profile',
          attributes: { email: email, properties: properties }
        }
      })
    }).catch(function () {});

    // 2. Subscribe to list (if list ID is configured)
    if (KLAVIYO_LIST_ID) {
      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_ID, {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'revision': '2023-12-15' },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: {
              profile: {
                data: {
                  type: 'profile',
                  attributes: { email: email, properties: properties }
                }
              }
            },
            relationships: {
              list: { data: { type: 'list', id: KLAVIYO_LIST_ID } }
            }
          }
        })
      }).catch(function () {});
    }
  }

})();
</script>

{% schema %}
{
  "name": "PGM — Quiz/Email Capture",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section image",
      "info": "Square or portrait photo of Mike coaching. Displays on the left panel."
    },
    { "type": "text",     "id": "heading",         "label": "Heading",            "default": "What's Your Posture Score?" },
    { "type": "textarea", "id": "subheading",       "label": "Subheading",         "default": "Take our free 2-minute Posture Score Quiz and get a personalized plan for fixing your specific pain points — delivered straight to your inbox." },
    { "type": "text",     "id": "placeholder",      "label": "Email placeholder",  "default": "Enter your email address" },
    { "type": "text",     "id": "cta_label",        "label": "Button label",       "default": "Get My Free Score →" },
    { "type": "text",     "id": "note",             "label": "Privacy note",       "default": "No spam, ever. Unsubscribe anytime. Join 50,000+ subscribers." },
    {
      "type": "header",
      "content": "Results screen"
    },
    { "type": "url",      "id": "trial_url",        "label": "Free trial URL" },
    { "type": "text",     "id": "result_cta_label", "label": "Results CTA label",  "default": "Start My Free Trial — Fix This Now" },
    {
      "type": "header",
      "content": "Klaviyo integration"
    },
    {
      "type": "text",
      "id": "klaviyo_id",
      "label": "Klaviyo Site ID (public key)",
      "default": "RY86tU",
      "info": "Found in Klaviyo → Account → API Keys. This is safe to expose publicly."
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo List ID (optional)",
      "info": "If set, quiz completers will be subscribed to this list. Find list IDs in Klaviyo → Lists & Segments."
    }
  ],
  "presets": [{ "name": "PGM — Quiz / Email Capture" }]
}
{% endschema %}
