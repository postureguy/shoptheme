{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}
{% comment %}PGM Quiz / Email Capture{% endcomment %}
<section class="pgm-quiz pgm-section" aria-labelledby="pgm-quiz-heading">

  <!-- Left: image panel -->
  <div class="pgm-quiz__image">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          alt: section.settings.image.alt | default: 'Mike Boshnack posture coaching session'
      }}
    {%- else -%}
      <img
        src="{{ 'pgm-quiz.jpg' | asset_url }}"
        alt="Mike Boshnack posture coaching session"
        loading="lazy"
        width="800"
        height="800"
      >
    {%- endif -%}
  </div>

  <!-- Right: content panel -->
  <div class="pgm-quiz__content">
    <div class="pgm-quiz__inner">

      <div class="pgm-quiz__icon" aria-hidden="true">🧠</div>

      <h2 class="pgm-quiz__h2" id="pgm-quiz-heading">
        {{ section.settings.heading }}
      </h2>
      <p class="pgm-quiz__sub">
        {{ section.settings.subheading | default: 'Take our free 2-minute Posture Score Quiz and get a personalized plan for fixing your specific pain points — delivered straight to your inbox.' }}
      </p>

      <!-- Perks -->
      <div class="pgm-quiz__perks" aria-label="What you'll get">
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Free personalized posture assessment
        </div>
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Custom exercise plan for your pain
        </div>
        <div class="pgm-quiz__perk">
          <span class="pgm-quiz__check" aria-hidden="true">✓</span>
          Weekly posture tips from Mike
        </div>
      </div>

      <!-- Email capture form -->
      {%- form 'customer', id: 'pgm-quiz-form', class: 'pgm-quiz__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,quiz-lead">
        <input
          type="email"
          name="contact[email]"
          id="pgm-quiz-email"
          class="pgm-quiz__input"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email address' }}"
          required
          autocomplete="email"
          aria-label="Email address"
        >
        <button type="submit" class="pgm-quiz__submit">
          {{ section.settings.cta_label | default: 'Get My Free Score →' }}
        </button>
      {%- endform -%}

      <p class="pgm-quiz__note">{{ section.settings.note | default: 'No spam, ever. Unsubscribe anytime.' }}</p>

    </div>
  </div>

</section>

{% comment %}
  KLAVIYO INTEGRATION NOTE:
  When Klaviyo is installed on this store, replace the Shopify `form 'customer'` above
  with Klaviyo's embed form (embed ID from your Klaviyo account) or use their API
  to post to a specific list. The styling classes (pgm-quiz__input, etc.) will still apply.

  Klaviyo embed example:
  <div class="klaviyo-form-XXXXXX"></div>
  <script async type="text/javascript" src="//static.klaviyo.com/onsite/js/klaviyo.js?company_id=YOUR_ID"></script>
{% endcomment %}

{% schema %}
{
  "name": "PGM — Quiz/Email Capture",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section image",
      "info": "Square or portrait photo of Mike coaching. Displays on the left panel."
    },
    { "type": "text",     "id": "heading",     "label": "Heading",         "default": "What's Your Posture Score?" },
    { "type": "textarea", "id": "subheading",  "label": "Subheading",      "default": "Take our free 2-minute Posture Score Quiz and get a personalized plan for fixing your specific pain points — delivered straight to your inbox." },
    { "type": "text",     "id": "placeholder", "label": "Input placeholder","default": "Enter your email address" },
    { "type": "text",     "id": "cta_label",   "label": "Button label",    "default": "Get My Free Score →" },
    { "type": "text",     "id": "note",        "label": "Privacy note",    "default": "No spam, ever. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "PGM — Quiz / Email Capture" }]
}
{% endschema %}
