{{ 'pgm-programs.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Program Videos
  Free teaser video section. Shows 1–3 YouTube embeds, then a blurred locked-content
  overlay CTA if show_locked_teaser is enabled.

  YouTube URL conversion:
    https://www.youtube.com/watch?v=VIDEO_ID  →  https://www.youtube.com/embed/VIDEO_ID
    https://youtu.be/VIDEO_ID                 →  https://www.youtube.com/embed/VIDEO_ID
{%- endcomment -%}

{%- assign prog = shop.metaobjects.program[section.settings.program_handle] -%}

{%- comment -%}
  Helper: extract YouTube video ID from a URL string.
  Supports watch?v=, youtu.be/, and embed/ formats.
{%- endcomment -%}

{%- liquid
  assign v1_url   = section.settings.video_1_url
  assign v1_title = section.settings.video_1_title
  assign v2_url   = section.settings.video_2_url
  assign v2_title = section.settings.video_2_title
  assign v3_url   = section.settings.video_3_url
  assign v3_title = section.settings.video_3_title

  comment
    Fall back to metaobject teaser URLs if schema URLs are blank
  endcomment

  if v1_url == blank
    assign v1_url = prog.teaser_video_1.value
  endif
  if v2_url == blank
    assign v2_url = prog.teaser_video_2.value
  endif
  if v3_url == blank
    assign v3_url = prog.teaser_video_3.value
  endif

  comment
    Fall back to metaobject titles
  endcomment
  if v1_title == blank
    assign v1_title = prog.teaser_video_1_title.value
  endif
  if v2_title == blank
    assign v2_title = prog.teaser_video_2_title.value
  endif
  if v3_title == blank
    assign v3_title = prog.teaser_video_3_title.value
  endif
-%}

{%- comment -%} Count visible videos {%- endcomment -%}
{%- assign video_count = 0 -%}
{%- if v1_url != blank -%}{%- assign video_count = video_count | plus: 1 -%}{%- endif -%}
{%- if v2_url != blank -%}{%- assign video_count = video_count | plus: 1 -%}{%- endif -%}
{%- if v3_url != blank -%}{%- assign video_count = video_count | plus: 1 -%}{%- endif -%}

{%- comment -%} Extract YouTube ID macro (done inline per video below) {%- endcomment -%}

{%- assign locked_count = section.settings.locked_video_count | default: 40 -%}
{%- assign program_url  = section.settings.program_url -%}
{%- if program_url == blank -%}
  {%- assign program_url = prog.page_url.value | default: '#' -%}
{%- endif -%}

<section
  class="pgm-program-videos pgm-section"
  id="pgm-program-videos-{{ section.id }}"
>
  <div class="pgm-program-videos__inner">

    <div class="pgm-program-videos__header">
      {%- if section.settings.section_heading != blank -%}
        <span class="pgm-program-videos__eyebrow">Free Sample Videos</span>
        <h2 class="pgm-program-videos__heading">{{ section.settings.section_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.section_subheading != blank -%}
        <p class="pgm-program-videos__subheading">{{ section.settings.section_subheading }}</p>
      {%- endif -%}
    </div>

    {%- if video_count > 0 -%}
      <div class="pgm-program-videos__grid{% if video_count == 2 %} pgm-program-videos__grid--2col{% endif %}">

        {%- comment -%} Video 1 {%- endcomment -%}
        {%- if v1_url != blank -%}
          {%- assign vid1_id = '' -%}
          {%- if v1_url contains 'watch?v=' -%}
            {%- assign vid1_parts = v1_url | split: 'watch?v=' -%}
            {%- assign vid1_id = vid1_parts[1] | split: '&' | first -%}
          {%- elsif v1_url contains 'youtu.be/' -%}
            {%- assign vid1_parts = v1_url | split: 'youtu.be/' -%}
            {%- assign vid1_id = vid1_parts[1] | split: '?' | first -%}
          {%- elsif v1_url contains 'embed/' -%}
            {%- assign vid1_parts = v1_url | split: 'embed/' -%}
            {%- assign vid1_id = vid1_parts[1] | split: '?' | first -%}
          {%- else -%}
            {%- assign vid1_id = v1_url -%}
          {%- endif -%}

          <div class="pgm-program-video-item">
            <div class="pgm-program-video-item__embed">
              <iframe
                src="https://www.youtube.com/embed/{{ vid1_id }}?rel=0&modestbranding=1"
                title="{{ v1_title | default: 'Free sample video' | escape }}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            {%- if v1_title != blank -%}
              <div class="pgm-program-video-item__info">
                <span class="pgm-program-video-item__label">Free Preview</span>
                <h3 class="pgm-program-video-item__title">{{ v1_title }}</h3>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Video 2 {%- endcomment -%}
        {%- if v2_url != blank -%}
          {%- assign vid2_id = '' -%}
          {%- if v2_url contains 'watch?v=' -%}
            {%- assign vid2_parts = v2_url | split: 'watch?v=' -%}
            {%- assign vid2_id = vid2_parts[1] | split: '&' | first -%}
          {%- elsif v2_url contains 'youtu.be/' -%}
            {%- assign vid2_parts = v2_url | split: 'youtu.be/' -%}
            {%- assign vid2_id = vid2_parts[1] | split: '?' | first -%}
          {%- elsif v2_url contains 'embed/' -%}
            {%- assign vid2_parts = v2_url | split: 'embed/' -%}
            {%- assign vid2_id = vid2_parts[1] | split: '?' | first -%}
          {%- else -%}
            {%- assign vid2_id = v2_url -%}
          {%- endif -%}

          <div class="pgm-program-video-item">
            <div class="pgm-program-video-item__embed">
              <iframe
                src="https://www.youtube.com/embed/{{ vid2_id }}?rel=0&modestbranding=1"
                title="{{ v2_title | default: 'Free sample video' | escape }}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            {%- if v2_title != blank -%}
              <div class="pgm-program-video-item__info">
                <span class="pgm-program-video-item__label">Free Preview</span>
                <h3 class="pgm-program-video-item__title">{{ v2_title }}</h3>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Video 3 {%- endcomment -%}
        {%- if v3_url != blank -%}
          {%- assign vid3_id = '' -%}
          {%- if v3_url contains 'watch?v=' -%}
            {%- assign vid3_parts = v3_url | split: 'watch?v=' -%}
            {%- assign vid3_id = vid3_parts[1] | split: '&' | first -%}
          {%- elsif v3_url contains 'youtu.be/' -%}
            {%- assign vid3_parts = v3_url | split: 'youtu.be/' -%}
            {%- assign vid3_id = vid3_parts[1] | split: '?' | first -%}
          {%- elsif v3_url contains 'embed/' -%}
            {%- assign vid3_parts = v3_url | split: 'embed/' -%}
            {%- assign vid3_id = vid3_parts[1] | split: '?' | first -%}
          {%- else -%}
            {%- assign vid3_id = v3_url -%}
          {%- endif -%}

          <div class="pgm-program-video-item">
            <div class="pgm-program-video-item__embed">
              <iframe
                src="https://www.youtube.com/embed/{{ vid3_id }}?rel=0&modestbranding=1"
                title="{{ v3_title | default: 'Free sample video' | escape }}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            {%- if v3_title != blank -%}
              <div class="pgm-program-video-item__info">
                <span class="pgm-program-video-item__label">Free Preview</span>
                <h3 class="pgm-program-video-item__title">{{ v3_title }}</h3>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- comment -%} Locked content teaser {%- endcomment -%}
    {%- if section.settings.show_locked_teaser -%}
      <div class="pgm-program-locked" aria-label="Unlock {{ locked_count }} more videos">
        <div class="pgm-program-locked__blur-grid" aria-hidden="true">
          {%- for i in (1..6) -%}
            <div class="pgm-program-locked__blur-item">
              <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                <path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h19A2.5 2.5 0 0 1 28 6.5v19a2.5 2.5 0 0 1-2.5 2.5h-19A2.5 2.5 0 0 1 4 25.5v-19zM13 11v10l8-5-8-5z"/>
              </svg>
            </div>
          {%- endfor -%}
        </div>

        <div class="pgm-program-locked__overlay">
          <div class="pgm-program-locked__lock-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>

          <h3 class="pgm-program-locked__headline">
            Unlock {{ locked_count }}+ More Videos
          </h3>

          <p class="pgm-program-locked__sub">
            Get full access to every exercise in this program — plus live classes, the full library, and Mike's private community.
          </p>

          <a href="{{ program_url }}" class="pgm-program-locked__cta">
            Unlock Full Program
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>

          <span class="pgm-program-locked__guarantee">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 1.5l.954 2.94h3.09l-2.5 1.818.954 2.936L8 7.386l-2.498 1.808.954-2.936-2.5-1.818h3.09L8 1.5z"/>
            </svg>
            30-day money-back guarantee · Cancel anytime
          </span>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PGM — Program Videos",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Metaobject Source"
    },
    {
      "type": "text",
      "id": "program_handle",
      "label": "Program handle",
      "info": "Handle of the `program` metaobject (e.g. forward-head-posture). Used to load teaser video URLs if schema fields are blank."
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Watch Free Sample Videos"
    },
    {
      "type": "textarea",
      "id": "section_subheading",
      "label": "Section subheading",
      "default": "See exactly what's inside the program before you commit."
    },
    {
      "type": "header",
      "content": "Video 1"
    },
    {
      "type": "url",
      "id": "video_1_url",
      "label": "YouTube URL",
      "info": "Full YouTube watch URL (e.g. https://www.youtube.com/watch?v=XXXXX). Leave blank to use metaobject."
    },
    {
      "type": "text",
      "id": "video_1_title",
      "label": "Video title",
      "info": "Displayed below the embed"
    },
    {
      "type": "header",
      "content": "Video 2"
    },
    {
      "type": "url",
      "id": "video_2_url",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "video_2_title",
      "label": "Video title"
    },
    {
      "type": "header",
      "content": "Video 3"
    },
    {
      "type": "url",
      "id": "video_3_url",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "video_3_title",
      "label": "Video title"
    },
    {
      "type": "header",
      "content": "Locked Content Teaser"
    },
    {
      "type": "checkbox",
      "id": "show_locked_teaser",
      "label": "Show locked content teaser",
      "default": true
    },
    {
      "type": "number",
      "id": "locked_video_count",
      "label": "Locked video count",
      "default": 40,
      "info": "Used in the \"Unlock X More Videos\" CTA"
    },
    {
      "type": "url",
      "id": "program_url",
      "label": "Unlock CTA link",
      "info": "Where the Unlock CTA button points. Falls back to metaobject page_url."
    }
  ],
  "presets": [
    {
      "name": "PGM — Program Videos"
    }
  ]
}
{% endschema %}
