{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-collab pgm-section" id="work-with-mike" aria-labelledby="pgm-collab-heading">
  <div class="pgm-collab__inner">

    <!-- Left: pitch copy -->
    <div class="pgm-collab__copy">
      <span class="pgm-eyebrow pgm-collab__eyebrow">{{ section.settings.eyebrow | default: 'Brand Partnerships' }}</span>
      <h2 class="pgm-collab__h2" id="pgm-collab-heading">
        {{ section.settings.heading | default: 'Partner With Posture Guy Mike' }}
      </h2>
      <p class="pgm-collab__body">
        {{ section.settings.body | default: 'Reach over 2.5 million engaged, health-conscious followers across Instagram, TikTok, YouTube, and Facebook. Our audience actively invests in their health — with a high percentage using HSA/FSA benefits for wellness purchases.' }}
      </p>

      <!-- Audience stats -->
      <div class="pgm-collab__stats" aria-label="Audience reach">
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">2.5M+</span>
          <span class="pgm-collab__stat-label">Total followers</span>
        </div>
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">15M+</span>
          <span class="pgm-collab__stat-label">Monthly impressions</span>
        </div>
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">5.9M</span>
          <span class="pgm-collab__stat-label">TikTok likes</span>
        </div>
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">35–65</span>
          <span class="pgm-collab__stat-label">Core age range</span>
        </div>
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">HSA/FSA</span>
          <span class="pgm-collab__stat-label">Eligible audience</span>
        </div>
        <div class="pgm-collab__stat">
          <span class="pgm-collab__stat-n">Celeb &amp; Pro</span>
          <span class="pgm-collab__stat-label">Athletes &amp; coaches</span>
        </div>
      </div>

      <!-- Worked with note -->
      <p class="pgm-collab__celeb-note">
        Mike has worked personally with celebrities, professional athletes, and sports teams — bringing the same elite-level posture correction to your audience that A-listers pay thousands for.
      </p>
    </div>

    <!-- Right: inquiry form -->
    <div class="pgm-collab__form-side">
      <h3 class="pgm-collab__form-heading">{{ section.settings.form_heading | default: 'Submit a Partnership Inquiry' }}</h3>

      {%- form 'contact', id: 'pgm-collab-form' -%}
        {%- if form.posted_successfully? -%}
          <p style="color:#60a5fa;font-size:1.6rem;font-weight:700;padding:2.4rem;background:rgba(29,78,216,.15);border-radius:var(--pgm-r);border:1px solid rgba(29,78,216,.3);">
            Thanks! We'll be in touch within 2 business days. 🎉
          </p>
        {%- else -%}
          <div class="pgm-collab__row">
            <div class="pgm-collab__field">
              <label class="pgm-collab__label" for="collab-name">Your Name *</label>
              <input type="text" id="collab-name" name="contact[name]" class="pgm-collab__input" placeholder="Jane Smith" required autocomplete="name">
            </div>
            <div class="pgm-collab__field">
              <label class="pgm-collab__label" for="collab-company">Company *</label>
              <input type="text" id="collab-company" name="contact[company]" class="pgm-collab__input" placeholder="Brand Inc." required>
            </div>
          </div>

          <div class="pgm-collab__field">
            <label class="pgm-collab__label" for="collab-email">Email Address *</label>
            <input type="email" id="collab-email" name="contact[email]" class="pgm-collab__input" placeholder="jane@brand.com" required autocomplete="email">
          </div>

          <div class="pgm-collab__field">
            <label class="pgm-collab__label" for="collab-type">Partnership Type *</label>
            <select id="collab-type" name="contact[partnership_type]" class="pgm-collab__select" required>
              <option value="" disabled selected>Select inquiry type</option>
              <optgroup label="Work With Mike">
                <option value="Private 1:1 Coaching">Private 1:1 Coaching Session</option>
                <option value="Corporate Wellness Program">Corporate Wellness Program</option>
                <option value="Speaking Engagement / Keynote">Speaking Engagement / Keynote</option>
              </optgroup>
              <optgroup label="Brand Partnerships">
                <option value="Sponsored Content (Instagram/TikTok)">Sponsored Content (Instagram/TikTok)</option>
                <option value="YouTube Integration">YouTube Integration</option>
                <option value="Email Campaign">Email Campaign Sponsorship</option>
                <option value="Product Collaboration">Product Collaboration / Bundle</option>
                <option value="Affiliate Program">Affiliate / Commission Program</option>
              </optgroup>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="pgm-collab__field">
            <label class="pgm-collab__label" for="collab-message">Tell us about your brand & goals</label>
            <textarea id="collab-message" name="contact[body]" class="pgm-collab__textarea" placeholder="Tell us about your inquiry — goals, timeline, and any relevant details."></textarea>
          </div>

          <input type="hidden" name="contact[form_type]" value="partnership_inquiry">

          <button type="submit" class="pgm-btn pgm-btn--primary" style="width:100%;justify-content:center;">
            {{ section.settings.submit_label | default: 'Submit Inquiry' }}
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Work With Mike",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",       "default": "Brand Partnerships" },
    { "type": "text",     "id": "heading",      "label": "Heading",       "default": "Partner With Posture Guy Mike" },
    { "type": "textarea", "id": "body",         "label": "Body",          "default": "Reach over 2.5 million engaged, health-conscious followers across Instagram, TikTok, YouTube, and Facebook." },
    { "type": "text",     "id": "form_heading", "label": "Form heading",  "default": "Submit a Partnership Inquiry" },
    { "type": "text",     "id": "submit_label", "label": "Submit button", "default": "Submit Inquiry" }
  ],
  "presets": [{ "name": "PGM — Work With Mike" }]
}
{% endschema %}
