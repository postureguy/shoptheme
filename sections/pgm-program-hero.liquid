{{ 'pgm-programs.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Program Hero
  Loads data from a `program` metaobject by handle.
  All fields have schema overrides that take precedence over metaobject values.
{%- endcomment -%}

{%- assign _prog_handle = section.settings.program_handle | default: page.handle -%}
{%- assign prog = shop.metaobjects.program[_prog_handle] -%}

{%- comment -%} Resolve title: schema override → metaobject → fallback {%- endcomment -%}
{%- if section.settings.title != blank -%}
  {%- assign hero_title = section.settings.title -%}
{%- elsif prog.title.value != blank -%}
  {%- assign hero_title = prog.title.value -%}
{%- else -%}
  {%- assign hero_title = page.title -%}
{%- endif -%}

{%- comment -%} Tagline {%- endcomment -%}
{%- if section.settings.tagline != blank -%}
  {%- assign hero_tagline = section.settings.tagline -%}
{%- elsif prog.tagline.value != blank -%}
  {%- assign hero_tagline = prog.tagline.value -%}
{%- endif -%}

{%- comment -%} Hero image {%- endcomment -%}
{%- if section.settings.hero_image != blank -%}
  {%- assign hero_image = section.settings.hero_image -%}
{%- elsif prog.hero_image.value != blank -%}
  {%- assign hero_image = prog.hero_image.value -%}
{%- endif -%}

{%- comment -%} Stats {%- endcomment -%}
{%- if section.settings.video_count != blank and section.settings.video_count > 0 -%}
  {%- assign hero_videos = section.settings.video_count -%}
{%- elsif prog.video_count.value != blank -%}
  {%- assign hero_videos = prog.video_count.value -%}
{%- endif -%}

{%- if section.settings.program_duration != blank -%}
  {%- assign hero_duration = section.settings.program_duration -%}
{%- elsif prog.program_duration.value != blank -%}
  {%- assign hero_duration = prog.program_duration.value -%}
{%- endif -%}

{%- if section.settings.difficulty != blank -%}
  {%- assign hero_difficulty = section.settings.difficulty -%}
{%- elsif prog.difficulty.value != blank -%}
  {%- assign hero_difficulty = prog.difficulty.value -%}
{%- endif -%}

{%- comment -%} Category {%- endcomment -%}
{%- assign hero_category = prog.condition_category.value -%}

{%- comment -%} CTA {%- endcomment -%}
{%- assign cta_label = section.settings.cta_label | default: 'Start This Program' -%}
{%- assign cta_url   = section.settings.cta_url -%}
{%- if cta_url == blank and prog.page_url.value != blank -%}
  {%- assign cta_url = prog.page_url.value -%}
{%- endif -%}

<section
  class="pgm-program-hero pgm-section"
  id="pgm-program-hero-{{ section.id }}"
  aria-label="{{ hero_title }}"
>

  {%- comment -%} Background image {%- endcomment -%}
  <div class="pgm-program-hero__bg" aria-hidden="true">
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: '',
          width: 2400,
          height: 1350
      }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#111827 0%,#1d2a40 50%,#0d1320 100%);"></div>
    {%- endif -%}
  </div>

  <div class="pgm-program-hero__overlay" aria-hidden="true"></div>

  <div class="pgm-program-hero__content">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="pgm-program-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="/pages/programs">Programs</a>
      <span class="pgm-program-hero__breadcrumb-sep" aria-hidden="true">›</span>
      {%- if hero_category != blank -%}
        <span>{{ hero_category }}</span>
        <span class="pgm-program-hero__breadcrumb-sep" aria-hidden="true">›</span>
      {%- endif -%}
      <span class="pgm-program-hero__breadcrumb-current" aria-current="page">{{ hero_title }}</span>
    </nav>

    {%- comment -%} Category pill {%- endcomment -%}
    {%- if hero_category != blank -%}
      <span class="pgm-program-hero__category">{{ hero_category }}</span>
    {%- endif -%}

    {%- comment -%} Title {%- endcomment -%}
    <h1 class="pgm-program-hero__title">{{ hero_title }}</h1>

    {%- comment -%} Tagline {%- endcomment -%}
    {%- if hero_tagline != blank -%}
      <p class="pgm-program-hero__tagline">{{ hero_tagline }}</p>
    {%- endif -%}

    {%- comment -%} Stats bar {%- endcomment -%}
    {%- if hero_videos != blank or hero_duration != blank or hero_difficulty != blank -%}
      <div class="pgm-program-hero__stats" role="list" aria-label="Program details">

        {%- if hero_videos != blank -%}
          <div class="pgm-program-hero__stat" role="listitem">
            <div class="pgm-program-hero__stat-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 4.5A1.5 1.5 0 0 1 4.5 3h11A1.5 1.5 0 0 1 17 4.5v11a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 3 15.5v-11z"/>
                <path d="M8 7.5l5 2.5-5 2.5V7.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <div class="pgm-program-hero__stat-label">Videos</div>
              <div class="pgm-program-hero__stat-value">{{ hero_videos }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if hero_duration != blank -%}
          <div class="pgm-program-hero__stat" role="listitem">
            <div class="pgm-program-hero__stat-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="10" r="7.5"/>
                <path d="M10 6.25v4.375l2.5 1.875"/>
              </svg>
            </div>
            <div>
              <div class="pgm-program-hero__stat-label">Duration</div>
              <div class="pgm-program-hero__stat-value">{{ hero_duration }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if hero_difficulty != blank -%}
          <div class="pgm-program-hero__stat" role="listitem">
            <div class="pgm-program-hero__stat-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 17l4-8 4 4 3-6 3 10"/>
              </svg>
            </div>
            <div>
              <div class="pgm-program-hero__stat-label">Level</div>
              <div class="pgm-program-hero__stat-value">{{ hero_difficulty }}</div>
            </div>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

    {%- comment -%} CTA {%- endcomment -%}
    <div class="pgm-program-hero__cta-wrap">
      {%- if cta_url != blank -%}
        <a href="{{ cta_url }}" class="pgm-program-hero__cta" aria-label="{{ cta_label }}">
          {{ cta_label }}
          <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5"/>
          </svg>
        </a>
      {%- endif -%}
      <span class="pgm-program-hero__trust-note">Free trial available · Cancel anytime</span>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Program Hero",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Metaobject Source"
    },
    {
      "type": "text",
      "id": "program_handle",
      "label": "Program handle",
      "info": "The handle of the `program` metaobject to load data from (e.g. forward-head-posture). Leave blank to use only manual overrides."
    },
    {
      "type": "header",
      "content": "Content Overrides"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title override",
      "info": "Leave blank to use metaobject title"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline override",
      "info": "Leave blank to use metaobject tagline"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image override",
      "info": "Leave blank to use metaobject image. Wide landscape crop, 2400×1350px recommended."
    },
    {
      "type": "header",
      "content": "Stats Bar Overrides"
    },
    {
      "type": "number",
      "id": "video_count",
      "label": "Video count override",
      "info": "Leave blank to use metaobject value"
    },
    {
      "type": "text",
      "id": "program_duration",
      "label": "Duration override",
      "info": "e.g. \"8 Weeks\" — leave blank to use metaobject value"
    },
    {
      "type": "text",
      "id": "difficulty",
      "label": "Difficulty override",
      "info": "e.g. \"Beginner\" — leave blank to use metaobject value"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Start This Program"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link",
      "info": "Link to the program page or checkout. Falls back to metaobject page_url."
    }
  ],
  "presets": [
    {
      "name": "PGM — Program Hero"
    }
  ]
}
{% endschema %}
