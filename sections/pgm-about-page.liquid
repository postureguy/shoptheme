<style>
/* ── About Page Styles ───────────────────────────────────────────── */

/* Shared */
.pgm-ap { font-family: var(--pgm-body); color: var(--pgm-dark); }
.pgm-ap__inner { max-width: 120rem; margin: 0 auto; padding: 0 2.4rem; }

/* ── 1. Hero ─────────────────────────────────────────────────────── */
.pgm-ap-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: var(--pgm-dark);
}
.pgm-ap-hero__bg {
  position: absolute;
  inset: 0;
}
.pgm-ap-hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 20%;
}
.pgm-ap-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(10,14,26,0.85) 60%, rgba(10,14,26,1) 100%);
}
.pgm-ap-hero__content {
  position: relative;
  width: 100%;
  padding: 8rem 2.4rem 7rem;
  max-width: 120rem;
  margin: 0 auto;
}
.pgm-ap-hero__eyebrow {
  display: inline-block;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pgm-blue);
  margin-bottom: 1.6rem;
}
.pgm-ap-hero__h1 {
  font-family: var(--pgm-head);
  font-size: clamp(3.2rem, 6vw, 5.6rem);
  font-weight: 800;
  line-height: 1.1;
  color: #fff;
  max-width: 80rem;
  margin-bottom: 2rem;
}
.pgm-ap-hero__sub {
  font-size: clamp(1.6rem, 2vw, 2rem);
  color: rgba(255,255,255,0.8);
  max-width: 64rem;
  line-height: 1.6;
  margin-bottom: 3.2rem;
}

/* ── 2. Origin Story ─────────────────────────────────────────────── */
