{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<section class="pgm-hero pgm-section" id="pgm-hero-{{ section.id }}">

  <!-- Background image or dark gradient -->
  <div class="pgm-hero__bg">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.bg_image.alt | default: 'Posture Guy Mike hero background'
      }}
    {%- endif -%}
  </div>
  <div class="pgm-hero__overlay"></div>

  <div class="pgm-hero__inner">

    <!-- Eyebrow chip -->
    <div class="pgm-hero__chip">
      <span class="pgm-hero__chip-dot"></span>
      {{ section.settings.eyebrow | default: 'Certified Postural Alignment Specialist' }}
    </div>

    <!-- H1 Headline -->
    <h1 class="pgm-hero__h1">
      {{ section.settings.headline }}
    </h1>

    <!-- Subheadline -->
    <p class="pgm-hero__sub">
      {{ section.settings.subheadline | default: 'Mike Boshnack has helped over a million people relieve chronic pain and fix their posture at home — without surgery, medication, or expensive appointments.' }}
    </p>

    <!-- CTAs -->
    <div class="pgm-hero__ctas">
      <a
        href="{{ section.settings.primary_cta_url | default: 'https://membership.postureguymike.com/checkout/new?o=151535' }}"
        class="pgm-btn pgm-btn--primary"
        target="_blank"
        rel="noopener"
        aria-label="{{ section.settings.primary_cta_label | default: 'Start Your Free Trial' }}"
      >
        {{ section.settings.primary_cta_label | default: 'Start Your Free Trial' }}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      {%- if section.settings.secondary_cta_label != blank -%}
        <a
          href="{{ section.settings.secondary_cta_url | default: '#pgm-about' }}"
          class="pgm-btn pgm-btn--outline"
        >
          {{ section.settings.secondary_cta_label | default: 'Watch How It Works' }}
        </a>
      {%- endif -%}
    </div>

    <!-- Trust signals -->
    <div class="pgm-hero__trust" aria-label="Social proof">
      <div class="pgm-hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
          <path d="M9 1l2.2 4.5L16 6.4l-3.5 3.4.8 4.8L9 12.3l-4.3 2.3.8-4.8L2 6.4l4.8-.9L9 1z"/>
        </svg>
        1.3M+ Instagram Followers
      </div>
      <span class="pgm-hero__trust-sep" aria-hidden="true"></span>
      <div class="pgm-hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
          <path d="M9 1l2.2 4.5L16 6.4l-3.5 3.4.8 4.8L9 12.3l-4.3 2.3.8-4.8L2 6.4l4.8-.9L9 1z"/>
        </svg>
        Free Trial · Cancel Anytime
      </div>
      <span class="pgm-hero__trust-sep" aria-hidden="true"></span>
      <div class="pgm-hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
          <path d="M9 1l2.2 4.5L16 6.4l-3.5 3.4.8 4.8L9 12.3l-4.3 2.3.8-4.8L2 6.4l4.8-.9L9 1z"/>
        </svg>
        HSA/FSA Eligible
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Hero",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Hero background image",
      "info": "Recommended: 2000×1200px, dark/moody image of Mike or Emily in action. Overlay is applied automatically."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Certified Postural Alignment Specialist"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline (HTML allowed for <em> blue text)",
      "default": "<p>Your Pain Has a<br><em>Root Cause.</em><br>Let's Fix It.</p>",
      "info": "Wrap words in <em> tags to colour them blue."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Mike Boshnack has helped over a million people relieve chronic pain and fix their posture at home — without surgery, medication, or expensive appointments."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Button label",
      "default": "Start Your Free Trial"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button link",
      "info": "Link to UScreen free trial checkout"
    },
    {
      "type": "header",
      "content": "Secondary CTA (optional)"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Button label",
      "default": "Watch How It Works"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "PGM — Hero"
    }
  ]
}
{% endschema %}
