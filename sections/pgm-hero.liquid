{{ 'pgm-home.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Home Hero
  Full-bleed hero with background image overlay, headline, dual CTAs, and trust note.
{%- endcomment -%}

{%- assign hero_eyebrow   = section.settings.eyebrow | default: '1.3M+ People Fixed Their Posture' -%}
{%- assign hero_heading   = section.settings.heading | default: 'Fix Your Posture. Feel Better. Move Better.' -%}
{%- assign hero_sub       = section.settings.subheading | default: 'Join over 2,400 members inside the Posture Guy Mike membership and get step-by-step programs built around your body.' -%}
{%- assign primary_label  = section.settings.primary_cta_label | default: 'Start Free Trial' -%}
{%- assign primary_url    = section.settings.primary_cta_url | default: 'https://membership.postureguymike.com/join' -%}
{%- assign secondary_label = section.settings.secondary_cta_label | default: 'Take the Posture Quiz' -%}

<section
  class="pgm-home-hero"
  id="pgm-home-hero-{{ section.id }}"
  aria-label="{{ hero_heading }}"
>

  {%- comment -%} Background {%- endcomment -%}
  <div class="pgm-home-hero__bg" aria-hidden="true">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: '',
          width: 2400,
          height: 1350,
          class: 'pgm-home-hero__bg-img'
      }}
    {%- else -%}
      <img src="{{ 'pgm-hero-desktop.jpg' | asset_url }}" alt="" class="pgm-home-hero__bg-img" loading="eager" fetchpriority="high" width="2400" height="1350">
    {%- endif -%}
  </div>

  <div class="pgm-home-hero__overlay" aria-hidden="true"></div>

  <div class="pgm-home-hero__content">

    {%- if hero_eyebrow != blank -%}
      <p class="pgm-home-hero__eyebrow">{{ hero_eyebrow }}</p>
    {%- endif -%}

    <h1 class="pgm-home-hero__heading">{{ hero_heading }}</h1>

    {%- if hero_sub != blank -%}
      <p class="pgm-home-hero__subheading">{{ hero_sub }}</p>
    {%- endif -%}

    <div class="pgm-home-hero__cta-wrap">
      <a
        href="{{ primary_url }}"
        class="pgm-home-hero__cta pgm-home-hero__cta--primary"
        aria-label="{{ primary_label }}"
        target="_blank"
        rel="noopener"
      >
        {{ primary_label }}
        <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18">
          <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5"/>
        </svg>
      </a>
      <button
        type="button"
        class="pgm-home-hero__cta pgm-home-hero__cta--secondary"
        data-video-id="{{ section.settings.video_id | default: 'b6Yt1JtvUH0' }}"
        aria-label="{{ secondary_label }}"
      >
        <span class="pgm-hero__play-ring" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
            <path d="M3.5 2.5l8 4.5-8 4.5z"/>
          </svg>
        </span>
        {{ secondary_label }}
      </button>
    </div>

    <p class="pgm-home-hero__trust-note">
      Free trial available&nbsp;·&nbsp;Cancel anytime&nbsp;·&nbsp;HSA/FSA eligible
    </p>

  </div>
</section>

{%- comment -%} Video Modal {%- endcomment -%}
<div
  class="pgm-vmodal"
  id="pgm-vmodal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="How It Works video"
  hidden
>
  <div class="pgm-vmodal__backdrop"></div>
  <div class="pgm-vmodal__dialog">
    <button class="pgm-vmodal__close" aria-label="Close video">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M15 5 5 15M5 5l10 10"/>
      </svg>
    </button>
    <div class="pgm-vmodal__video-wrap">
      <div class="pgm-vmodal__embed" id="pgm-vmodal-embed-{{ section.id }}"></div>
    </div>
  </div>
</div>

<script>
(function () {
  var sectionId = '{{ section.id }}';
  var modal     = document.getElementById('pgm-vmodal-' + sectionId);
  var embed     = document.getElementById('pgm-vmodal-embed-' + sectionId);
  var trigger   = document.querySelector('#pgm-home-hero-' + sectionId + ' [data-video-id]');

  if (!trigger || !modal) return;

  function openModal() {
    var vid = trigger.getAttribute('data-video-id');
    embed.innerHTML =
      '<iframe src="https://www.youtube-nocookie.com/embed/' + vid +
      '?autoplay=1&rel=0&modestbranding=1" frameborder="0" ' +
      'allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>';
    modal.removeAttribute('hidden');
    document.body.classList.add('pgm-modal-open');
    modal.querySelector('.pgm-vmodal__close').focus();
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    embed.innerHTML = '';
    document.body.classList.remove('pgm-modal-open');
    trigger.focus();
  }

  trigger.addEventListener('click', openModal);
  modal.querySelector('.pgm-vmodal__backdrop').addEventListener('click', closeModal);
  modal.querySelector('.pgm-vmodal__close').addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "PGM — Home Hero",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "1.3M+ People Fixed Their Posture"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Fix Your Posture. Feel Better. Move Better."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheadline",
      "default": "Join over 2,400 members inside the Posture Guy Mike membership and get step-by-step programs built around your body."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary button label",
      "default": "Start Free Trial"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary button label",
      "default": "Take the Posture Quiz"
    },
    {
      "type": "text",
      "id": "video_id",
      "label": "YouTube Video ID",
      "default": "b6Yt1JtvUH0",
      "info": "The ID from the YouTube URL — e.g. for youtube.com/watch?v=b6Yt1JtvUH0 enter b6Yt1JtvUH0"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image",
      "info": "Wide landscape, 2400×1350px recommended. Dark gradient used if blank."
    }
  ],
  "presets": [
    {
      "name": "PGM — Home Hero"
    }
  ]
}
{% endschema %}
