{{ 'pgm-home.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Home Instagram
  Instagram feed placeholder section. Shows a 6-cell grid of placeholder tiles
  with an Instagram icon and a follow CTA, since Liquid cannot directly fetch
  live Instagram feed data. Connect a third-party Instagram feed app (e.g. Instafeed)
  and replace the placeholder grid with the app embed if desired.
{%- endcomment -%}

{%- assign ig_heading  = section.settings.heading | default: 'Follow Along' -%}
{%- assign ig_handle   = section.settings.handle  | default: '@postureguymike' -%}
{%- assign ig_url      = 'https://www.instagram.com/postureguymike/' -%}
{%- assign ig_followers = section.settings.follower_count | default: '1.3M+' -%}

<section
  class="pgm-home-instagram"
  id="pgm-home-instagram-{{ section.id }}"
  aria-labelledby="pgm-home-instagram-heading-{{ section.id }}"
>
  <div class="pgm-home-instagram__inner">

    <div class="pgm-home-instagram__header">

      <div class="pgm-home-instagram__header-text">
        <h2 class="pgm-home-instagram__heading" id="pgm-home-instagram-heading-{{ section.id }}">
          {{ ig_heading }}
        </h2>
        <a
          href="{{ ig_url }}"
          class="pgm-home-instagram__handle"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow {{ ig_handle }} on Instagram"
        >
          <svg class="pgm-home-instagram__ig-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="20">
            <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
          {{ ig_handle }}
        </a>
      </div>

      <div class="pgm-home-instagram__header-meta">
        <span class="pgm-home-instagram__follower-count">{{ ig_followers }}</span>
        <span class="pgm-home-instagram__follower-label">Followers</span>
      </div>

    </div>

    {%- comment -%} Placeholder grid — 6 tiles {%- endcomment -%}
    <div class="pgm-home-instagram__grid" aria-label="Instagram feed preview" role="list">
      {%- for i in (1..6) -%}
        <a
          href="{{ ig_url }}"
          class="pgm-home-instagram__tile"
          target="_blank"
          rel="noopener noreferrer"
          role="listitem"
          aria-label="View post {{ i }} on Instagram"
        >
          <div class="pgm-home-instagram__tile-inner" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
              <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="4" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="rgba(255,255,255,0.5)"/>
            </svg>
          </div>
        </a>
      {%- endfor -%}
    </div>

    <div class="pgm-home-instagram__follow-wrap">
      <a
        href="{{ ig_url }}"
        class="pgm-home-instagram__follow-cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Follow {{ ig_handle }} on Instagram"
      >
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="18" height="18">
          <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
        Follow on Instagram
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "PGM — Home Instagram",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Follow Along"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle",
      "default": "@postureguymike"
    },
    {
      "type": "text",
      "id": "follower_count",
      "label": "Follower count display",
      "default": "1.3M+",
      "info": "Displayed next to the heading. Update manually as needed."
    }
  ],
  "presets": [
    {
      "name": "PGM — Home Instagram"
    }
  ]
}
{% endschema %}
