<div class="pgm-dcards pgm-section">
  <div class="pgm-dcards__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="pgm-dcards__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="pgm-dcards__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="pgm-dcards__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <div class="pgm-dcards__card" {{ block.shopify_attributes }}>
            <div class="pgm-dcards__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'cert' -%}   {{ icon_cert }}
                {%- when 'people' -%} {{ icon_people }}
                {%- when 'star' -%}   {{ icon_star }}
                {%- when 'media' -%}  {{ icon_media }}
                {%- when 'hsa' -%}    {{ icon_hsa }}
                {%- else -%}          {{ icon_star }}
              {%- endcase -%}
            </div>
            <div class="pgm-dcards__title">{{ block.settings.title }}</div>
            <p class="pgm-dcards__body">{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "PGM — Dark Cards",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "cert",
          "options": [
            { "value": "cert",   "label": "Shield / Certified" },
            { "value": "people", "label": "People / Community" },
            { "value": "star",   "label": "Star / Social" },
            { "value": "media",  "label": "Media / Press" },
            { "value": "hsa",    "label": "Dollar / HSA" }
          ]
        },
        { "type": "text",     "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body",  "label": "Body text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Dark Cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
