{{ 'pgm-homepage.css' | asset_url | stylesheet_tag }}

<style>
.pgm-dcards {
  background: var(--pgm-dark);
  padding: 9.6rem 0;
}
.pgm-dcards__inner {
  max-width: 120rem;
  margin: 0 auto;
  padding: 0 2.4rem;
}
.pgm-dcards__eyebrow {
  display: block;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pgm-blue);
  text-align: center;
  margin-bottom: 1.2rem;
}
.pgm-dcards__heading {
  font-family: var(--pgm-head);
  font-size: clamp(2.4rem, 3vw, 3.6rem);
  font-weight: 800;
  color: #fff;
  text-align: center;
  max-width: 72rem;
  margin: 0 auto 5.6rem;
  line-height: 1.2;
}
.pgm-dcards__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3.2rem;
}
.pgm-dcards__card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 1.6rem;
  padding: 3.2rem;
}
.pgm-dcards__icon {
  width: 4.8rem;
  height: 4.8rem;
  background: var(--pgm-blue);
  border-radius: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
}
.pgm-dcards__icon svg { width: 2.4rem; height: 2.4rem; fill: white; }
.pgm-dcards__title {
  font-family: var(--pgm-head);
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 1rem;
}
.pgm-dcards__body {
  font-size: 1.5rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.65);
}
@media (max-width: 989px) {
  .pgm-dcards__grid { grid-template-columns: 1fr; }
  .pgm-dcards { padding: 6.4rem 0; }
}
</style>

