{{ 'pgm-programs.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  PGM — Program Content
  Long-form SEO content section.
  Loads `seo_description` from metaobject, with schema overrides for heading and content.
{%- endcomment -%}

{%- assign _prog_handle = section.settings.program_handle | default: page.handle -%}
{%- assign prog = shop.metaobjects.program[_prog_handle] -%}

{%- comment -%} Resolve heading {%- endcomment -%}
{%- if section.settings.heading != blank -%}
  {%- assign content_heading = section.settings.heading -%}
{%- elsif prog.seo_heading.value != blank -%}
  {%- assign content_heading = prog.seo_heading.value -%}
{%- elsif prog.title.value != blank -%}
  {%- assign content_heading = 'About the ' | append: prog.title.value | append: ' Program' -%}
{%- endif -%}

{%- comment -%} Resolve eyebrow {%- endcomment -%}
{%- assign content_eyebrow = section.settings.eyebrow | default: 'Program Overview' -%}

{%- comment -%} Resolve content: schema richtext → metaobject seo_description {%- endcomment -%}
{%- if section.settings.content != blank -%}
  {%- assign content_body = section.settings.content -%}
  {%- assign content_is_richtext = true -%}
{%- elsif prog.seo_description.value != blank -%}
  {%- assign content_body = prog.seo_description.value -%}
  {%- assign content_is_richtext = false -%}
{%- endif -%}

{%- assign bg_class = 'pgm-program-content--' | append: section.settings.background | default: 'pgm-program-content--white' -%}

<section
  class="pgm-program-content {{ bg_class }} pgm-section"
  id="pgm-program-content-{{ section.id }}"
>
  <div class="pgm-program-content__inner">

    {%- if content_eyebrow != blank -%}
      <span class="pgm-program-content__eyebrow">{{ content_eyebrow }}</span>
    {%- endif -%}

    {%- if content_heading != blank -%}
      <h2 class="pgm-program-content__heading">{{ content_heading }}</h2>
    {%- endif -%}

    {%- if content_body != blank -%}
      <div class="pgm-program-content__prose">
        {%- assign _has_mid_image = false -%}
        {%- assign _mid_image_src = '' -%}
        {%- if section.settings.mid_image != blank -%}
          {%- assign _has_mid_image = true -%}
          {%- assign _mid_image_src = section.settings.mid_image | image_url: width: 960 -%}
          {%- assign _split_at = section.settings.split_paragraph | default: 2 -%}
        {%- elsif page.handle == 'forward-head-posture' -%}
          {%- assign _has_mid_image = true -%}
          {%- assign _mid_image_src = 'forward-head-posture-spine-diagram.jpg' | asset_url -%}
          {%- assign _split_at = 2 -%}
        {%- elsif page.handle == 'hip-alignment' -%}
          {%- assign _has_mid_image = true -%}
          {%- assign _mid_image_src = 'spine-photo.jpg' | asset_url -%}
          {%- assign _split_at = 2 -%}
        {%- elsif page.handle == 'kyphosis' -%}
          {%- assign _has_mid_image = true -%}
          {%- assign _mid_image_src = 'kyphosis-photo.jpg' | asset_url -%}
          {%- assign _split_at = 2 -%}
        {%- endif -%}

        {%- if content_is_richtext -%}
          {{ content_body }}
        {%- else -%}
          {{ content_body | newline_to_br }}
        {%- endif -%}

        {%- if _has_mid_image -%}
          <figure class="pgm-program-content__mid-image">
            <img
              src="{{ _mid_image_src }}"
              alt="{{ section.settings.mid_image_alt | default: 'Posture Guy Mike' }}"
              loading="lazy"
              width="960"
              style="width:100%;height:auto;border-radius:8px;"
            >
          </figure>
        {%- endif -%}

        {%- if page.content != blank -%}
          {%- if page.handle == 'forward-head-posture' -%}
            {%- comment -%} Inject comparison image after H2 #2 "What Causes FHP?" {%- endcomment -%}
            {%- assign _pc_parts = page.content | split: '<h2' -%}
            {%- for _part in _pc_parts -%}
              {%- if forloop.first -%}{{ _part }}{%- else -%}{{ '<h2' | append: _part }}{%- endif -%}
              {%- if forloop.index == 3 -%}
                <div class="pgm-program-content__img-divider"><span>What Does Corrected Posture Look Like?</span></div>
                <figure class="pgm-program-content__mid-image pgm-program-content__mid-image--wide">
                  <img src="{{ 'fhp-comparison.jpg' | asset_url }}" alt="Forward Head Posture vs Neutral Head Posture comparison" loading="lazy" width="1536" height="1024">
                </figure>
              {%- endif -%}
            {%- endfor -%}

          {%- elsif page.handle == 'kyphosis' -%}
            {%- comment -%} Inject spine overlay after H2 #2, comparison after H2 #3 {%- endcomment -%}
            {%- assign _pc_parts = page.content | split: '<h2' -%}
            {%- for _part in _pc_parts -%}
              {%- if forloop.first -%}{{ _part }}{%- else -%}{{ '<h2' | append: _part }}{%- endif -%}
              {%- if forloop.index == 3 -%}
                <div class="pgm-program-content__img-divider"><span>What Kyphosis Does to Your Spine</span></div>
                <figure class="pgm-program-content__mid-image pgm-program-content__mid-image--wide">
                  <img src="{{ 'kyphosis-spine-overlay.jpg' | asset_url }}" alt="Kyphosis spinal curvature diagram" loading="lazy" width="1536" height="1024">
                </figure>
              {%- endif -%}
              {%- if forloop.index == 4 -%}
                <div class="pgm-program-content__img-divider"><span>Good Posture vs Kyphosis</span></div>
                <figure class="pgm-program-content__mid-image pgm-program-content__mid-image--wide">
                  <img src="{{ 'kyphosis-comparison.jpg' | asset_url }}" alt="Good posture vs kyphosis comparison" loading="lazy" width="1536" height="1024">
                </figure>
              {%- endif -%}
            {%- endfor -%}

          {%- elsif page.handle == 'neck-hump' -%}
            {%- comment -%} Image 1 before H2 content — breaks up intro text {%- endcomment -%}
            <div class="pgm-program-content__img-divider"><span>What Neck Hump Poor Posture Looks Like</span></div>
            <figure class="pgm-program-content__mid-image pgm-program-content__mid-image--wide">
              <img src="{{ 'neck-hump-image-1.jpg' | asset_url }}" alt="Neck hump poor posture demonstrated" loading="lazy" width="1536" height="1024">
            </figure>
            {%- comment -%} Image 2 after H2 #3 "Why a Neck Hump Gets Worse" {%- endcomment -%}
            {%- assign _pc_parts = page.content | split: '<h2' -%}
            {%- for _part in _pc_parts -%}
              {%- if forloop.first -%}{{ _part }}{%- else -%}{{ '<h2' | append: _part }}{%- endif -%}
              {%- if forloop.index == 4 -%}
                <div class="pgm-program-content__img-divider"><span>Good Posture vs Neck Hump</span></div>
                <figure class="pgm-program-content__mid-image pgm-program-content__mid-image--wide">
                  <img src="{{ 'neck-hump-image-2.jpg' | asset_url }}" alt="Good posture vs neck hump comparison" loading="lazy" width="1536" height="1024">
                </figure>
              {%- endif -%}
            {%- endfor -%}

          {%- else -%}
            {{ page.content }}
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PGM — Program Content",
  "tag": "section",
  "class": "pgm-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Metaobject Source"
    },
    {
      "type": "text",
      "id": "program_handle",
      "label": "Program handle",
      "info": "Handle of the `program` metaobject to load seo_description from (e.g. forward-head-posture)"
    },
    {
      "type": "header",
      "content": "Content Overrides"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Program Overview"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override",
      "info": "Leave blank to auto-generate from metaobject title"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content override",
      "info": "Rich text body. If blank, loads seo_description from metaobject."
    },
    {
      "type": "header",
      "content": "Mid-Content Image"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Image",
      "info": "Displayed between paragraphs to break up the text"
    },
    {
      "type": "text",
      "id": "mid_image_alt",
      "label": "Image alt text",
      "default": "Posture Guy Mike"
    },
    {
      "type": "range",
      "id": "split_paragraph",
      "label": "Insert after paragraph #",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2,
      "info": "Image appears after this paragraph number"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background color",
      "default": "white",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "light", "label": "Light gray" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PGM — Program Content"
    }
  ]
}
{% endschema %}
